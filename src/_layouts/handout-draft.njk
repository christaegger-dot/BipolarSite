<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="robots" content="noindex, nofollow">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} – Handout-Draft</title>
  <link rel="stylesheet" href="{{ '/fonts/fonts.css' | previewRelativeUrl }}">
  <style>
    /*
     * Standalone token set for the print/PDF handout layout.
     * This layout loads NO shared CSS (tokens.css, shared.css, etc.)
     * so it must declare its own :root variables.
     *
     * Intentional differences from tokens.css:
     *   --teal      → #3a9aa3 (opaque) vs rgba(58,154,163,0.75) — print needs solid color
     *   --alert     → #9a3412 (burnt orange) vs #B91C1C — warmer tone for handout context
     *   --text      → #2d2823 (darker) vs #7a6f66 — higher contrast for print readability
     *   --text-2xl  → 1.9rem vs 2.2rem — tighter heading scale to fit A4 page
     *   --muted, --line, --warm, --paper, --teal-soft, --shadow — print-specific tokens
     *       not present or differently defined in tokens.css
     *
     * Matching values (same as tokens.css):
     *   --navy, --sand, --text-xs, --text-sm, --text-base, --text-lg, --text-xl
     */
    :root{
      --navy:#7a6f66;
      --teal:#3a9aa3;
      --teal-soft:#d9ecec;
      --warm:#fcf8f4;
      --sand:#ddd2bf;
      --alert:#9a3412;
      --text:#2d2823;
      --muted:#5c5a56;
      --line:rgba(45,40,35,0.12);
      --paper:#fffdf9;
      --shadow:0 18px 42px rgba(28,43,58,0.12);
      --text-xs:0.75rem;
      --text-sm:0.875rem;
      --text-base:1rem;
      --text-lg:1.25rem;
      --text-xl:1.6rem;
      --text-2xl:1.9rem;
    }

    *{box-sizing:border-box}
    html{background:#efe8df}
    body{
      margin:0;
      font-family:'DM Sans',sans-serif;
      color:var(--text);
      background: #f4eee6;
      line-height:1.6;
    }

    a{color:var(--teal-text)}

    .draft-shell{
      width:min(1120px, calc(100% - 32px));
      margin:32px auto 48px;
    }

    .draft-toolbar{
      display:flex;
      gap:var(--grid-gap-tight);
      justify-content:space-between;
      align-items:flex-start;
      margin-bottom:18px;
      flex-wrap:wrap;
    }

    .draft-intro{
      max-width:56ch;
      color:var(--muted);
      font-size:var(--text-base);
    }

    .draft-actions{
      display:flex;
      gap:var(--grid-gap-tight);
      flex-wrap:wrap;
    }

    .draft-chip,
    .draft-link{
      display:inline-flex;
      align-items:center;
      gap:8px;
      min-height:40px;
      padding:10px 14px;
      border-radius:var(--radius-round);
      text-decoration:none;
      font-size:var(--text-sm);
      font-weight:700;
      border:1px solid var(--line);
      background:rgba(255,255,255,0.7);
      color:var(--navy);
      backdrop-filter:blur(8px);
    }

    .draft-link.primary{
      background:var(--teal-cta);
      color:#fff;
      border-color:transparent;
    }

    .draft-paper{
      width:210mm;
      min-height:297mm;
      margin:0 auto;
      background:var(--paper);
      box-shadow:var(--shadow);
      border:1px solid rgba(45,40,35,0.08);
      display:flex;
      flex-direction:column;
    }

    .draft-header{
      padding:22mm 18mm 10mm;
      border-bottom:1px solid rgba(45,40,35,0.08);
      background: rgba(252,248,244,0.95);
    }

    .draft-header.alert-mode{
      background: rgba(252,243,239,0.98);
    }

    .draft-kicker{
      display:flex;
      gap:var(--grid-gap-tight);
      flex-wrap:wrap;
      align-items:center;
      margin-bottom:12px;
    }

    .draft-badge{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:5px 10px;
      border-radius:var(--radius-round);
      background:var(--teal-soft);
      color:var(--navy);
      font-size:var(--text-xs);
      font-weight:700;
      letter-spacing:0.03em;
    }

    .draft-badge.alert{background:#f6ddd5;color:var(--alert)}
    .draft-title{
      font-family:'DM Serif Display',serif;
      font-size:var(--text-2xl);
      line-height:1.12;
      letter-spacing:-0.02em;
      margin:0 0 10px;
      color:var(--navy);
    }

    .draft-subtitle{
      font-size:var(--text-base);
      color:var(--muted);
      max-width:58ch;
      margin:0 0 12px;
    }

    .draft-meta{
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:0;
      margin-top:14px;
      padding-top:12px;
      border-top:1px solid rgba(45,40,35,0.08);
    }

    .draft-meta-card{
      padding:0 14px 0 0;
      min-width:0;
    }

    .draft-meta-card + .draft-meta-card{
      padding:0 0 0 16px;
      border-left:1px solid rgba(45,40,35,0.08);
    }

    .draft-meta-label{
      font-size:var(--text-xs);
      font-weight:700;
      letter-spacing:0.03em;
      color:#6f6b65;
      margin-bottom:3px;
    }

    .draft-meta-value{
      font-size:var(--text-base);
      color:var(--text);
      font-weight:600;
      min-width:0;
      overflow-wrap:anywhere;
      word-break:break-word;
    }

    .draft-alert-panel{
      margin-top:18px;
      border:1px solid rgba(154,52,18,0.18);
      border-radius:var(--card-radius);
      background: rgba(250,233,227,0.95);
      padding:16px;
      display:grid;
      grid-template-columns:minmax(0,1.2fr) minmax(0,0.8fr);
      gap:var(--grid-gap-tight);
    }

    .draft-alert-eyebrow{
      font-size:var(--text-xs);
      font-weight:700;
      letter-spacing:0.03em;
      color:var(--alert);
      margin-bottom:7px;
    }

    .draft-alert-line{
      font-size:var(--text-base);
      line-height:1.15;
      color:#68200b;
      margin:0 0 10px;
      font-weight:700;
    }

    .draft-alert-copy{
      margin:0;
      color:#5d372e;
      font-size:var(--text-base);
      max-width:44ch;
    }

    .draft-quick-steps{
      display:grid;
      gap:var(--grid-gap-tight);
      align-content:start;
    }

    .draft-step{
      display:grid;
      grid-template-columns:34px minmax(0,1fr);
      gap:var(--grid-gap-tight);
      align-items:start;
      padding:10px 12px;
      border-radius:var(--radius-md);
      background:rgba(255,255,255,0.62);
      border:1px solid rgba(154,52,18,0.08);
    }

    .draft-step-index{
      width:34px;
      height:34px;
      border-radius:var(--radius-round);
      display:grid;
      place-items:center;
      background:#9a3412;
      color:#fff;
      font-weight:800;
      font-size:var(--text-base);
      box-shadow:0 8px 18px rgba(154,52,18,0.16);
    }

    .draft-step-index.icon{
      font-size:var(--text-base);
      line-height:1;
    }

    .draft-step-index.wide{
      width:auto;
      min-width:34px;
      padding:0 8px;
      border-radius:var(--radius-round);
      font-size:var(--text-xs);
    }

    .draft-step-text{
      font-size:var(--text-base);
      line-height:1.5;
      color:var(--navy);
      font-weight:600;
      min-width:0;
      overflow-wrap:anywhere;
    }

    .draft-number-bar{
      margin:1.35rem 0 1.1rem;
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(180px, 1fr));
      gap:var(--grid-gap-tight);
    }

    .draft-number-card{
      border-radius:var(--card-radius);
      border:1px solid rgba(45,40,35,0.08);
      background:rgba(245,241,235,0.95);
      padding:12px 14px;
      min-width:0;
    }

    .draft-number-card.urgent{
      border-color:rgba(154,52,18,0.18);
      background:rgba(250,233,227,0.96);
    }

    .draft-number-label{
      font-size:var(--text-xs);
      font-weight:700;
      letter-spacing:0.03em;
      color:#6f6b65;
      margin-bottom:4px;
    }

    .draft-number-card.urgent .draft-number-label{
      color:var(--alert);
    }

    .draft-number-value{
      font-size:var(--text-lg);
      line-height:1.15;
      color:var(--navy);
      font-weight:700;
      min-width:0;
      overflow-wrap:anywhere;
    }

    .draft-number-card.urgent .draft-number-value{
      color:#68200b;
    }

    .draft-number-note{
      margin-top:6px;
      font-size:var(--text-xs);
      line-height:1.5;
      color:var(--muted);
    }

    .draft-content{
      padding:14mm 18mm 18mm;
      font-size:var(--text-base);
    }

    .draft-content > :first-child{margin-top:0}
    .draft-content h1{display:none}
    .draft-content h2{
      font-family:'DM Serif Display',serif;
      font-size:var(--text-lg);
      line-height:1.2;
      color:var(--navy);
      margin:1.6rem 0 0.65rem;
      padding-bottom:0.25rem;
      border-bottom:1px solid rgba(45,40,35,0.08);
    }

    .draft-content h3{
      font-size:var(--text-base);
      line-height:1.5;
      color:var(--navy);
      margin:1.15rem 0 0.45rem;
    }

    .draft-content p{margin:0.55rem 0}
    .draft-content > p:first-of-type{
      font-size:var(--text-base);
      line-height:1.75;
      margin-bottom:1rem;
    }
    .draft-content ul{margin:0.55rem 0 0.8rem 1.15rem;padding:0}
    .draft-content li{margin:0.2rem 0}
    .draft-content strong{color:var(--navy)}
    .draft-content code{
      background:#f2eee8;
      border-radius:var(--radius-sm);
      padding:1px 6px;
      font-size:0.9em;
    }

    .draft-footer{
      margin-top:auto;
      border-top:1px solid rgba(45,40,35,0.08);
      padding:10mm 18mm 14mm;
      display:flex;
      justify-content:space-between;
      gap:var(--grid-gap-tight);
      flex-wrap:wrap;
      color:#6f6b65;
      font-size:var(--text-xs);
      background:rgba(255,255,255,0.92);
    }

    .draft-footer-status{
      color:#877f76;
    }

    @media (max-width: 900px){
      .draft-shell{width:min(100%, calc(100% - 20px));margin:18px auto 28px}
      .draft-paper{width:100%;min-height:auto}
      .draft-header,.draft-content,.draft-footer{padding-left:20px;padding-right:20px}
      .draft-header{padding-top:22px}
      .draft-content{padding-top:20px;padding-bottom:24px}
      .draft-footer{padding-top:18px}
      .draft-meta{grid-template-columns:1fr}
      .draft-meta-card{padding:0}
      .draft-meta-card + .draft-meta-card{
        padding:12px 0 0;
        margin-top:12px;
        border-left:none;
        border-top:1px solid rgba(45,40,35,0.08);
      }
      .draft-title{font-size:var(--text-xl)}
      .draft-alert-panel{grid-template-columns:1fr;padding:16px}
      .draft-alert-line{font-size:var(--text-base)}
    }

    @media print{
      @page{size:A4;margin:12mm 14mm}
      html,body{background:#fff}
      .draft-shell{width:auto;margin:0}
      .draft-toolbar{display:none}
      .draft-paper{
        width:auto;
        min-height:auto;
        margin:0;
        box-shadow:none;
        border:none;
      }
      /* Compress padding for max content area */
      .draft-header{padding:8mm 0 6mm}
      .draft-content{padding:6mm 0 8mm}
      .draft-footer{padding:4mm 0 0}
      .draft-header,.draft-content,.draft-footer{
        padding-left:0;
        padding-right:0;
      }
      a{color:inherit;text-decoration:none}
      .draft-footer-status{display:none}
      /* Compact title & badges */
      .draft-kicker{margin-bottom:4px;gap:6px}
      .draft-badge{padding:2px 7px;font-size:0.65rem}
      .draft-title{font-size:1.4rem;margin:0 0 4px;line-height:1.15}
      .draft-subtitle{font-size:0.9rem;margin:0 0 6px;line-height:1.35}
      /* Compact meta row */
      .draft-meta{margin-top:6px;padding-top:6px;gap:0}
      .draft-meta-label{font-size:0.6rem;margin-bottom:1px}
      .draft-meta-value{font-size:0.85rem}
      /* Compact alert panel */
      .draft-alert-panel{
        margin-top:8px;
        padding:10px;
        gap:8px;
        break-inside:avoid;
      }
      .draft-alert-eyebrow{font-size:0.6rem;margin-bottom:3px}
      .draft-alert-line{font-size:0.85rem;margin:0 0 4px}
      .draft-alert-copy{font-size:0.8rem;line-height:1.4}
      .draft-step{
        padding:6px 8px;
        gap:8px;
        grid-template-columns:24px minmax(0,1fr);
        break-inside:avoid;
      }
      .draft-step-index{width:24px;height:24px;font-size:0.7rem}
      .draft-step-text{font-size:0.8rem}
      /* Compact emergency contacts */
      .draft-number-bar{margin:0.5rem 0;gap:6px;grid-template-columns:repeat(3,1fr)}
      .draft-number-card{padding:6px 8px}
      .draft-number-label{font-size:0.6rem;margin-bottom:1px}
      .draft-number-value{font-size:0.85rem}
      .draft-number-note{font-size:0.6rem;margin-top:2px}
      /* Compact content headings & text */
      .draft-content h2{
        font-size:1.05rem;
        margin:0.7rem 0 0.3rem;
        padding-bottom:0.15rem;
        break-after:avoid;
      }
      .draft-content h3{
        font-size:0.9rem;
        margin:0.5rem 0 0.25rem;
      }
      .draft-content p{margin:0.25rem 0;font-size:0.85rem;line-height:1.45}
      .draft-content > p:first-of-type{font-size:0.85rem;line-height:1.5;margin-bottom:0.5rem}
      .draft-content ul{margin:0.25rem 0 0.4rem 1rem}
      .draft-content li{margin:0.1rem 0;font-size:0.85rem;line-height:1.4}
      .draft-content strong{color:#000}
      /* Compact footer */
      .draft-footer{font-size:0.6rem;border-top:1px solid #ccc}
    }
  </style>
</head>
<body>
  <div class="draft-shell">
    <div class="draft-toolbar">
      <div class="draft-intro">
        Dies ist eine wartbare HTML-Voransicht für den Neuaufbau eines Handouts. Sie dient als Zwischenstufe für redaktionelle Prüfung, Layout-Feinschliff und späteren PDF-Export.
      </div>
      <div class="draft-actions">
        <span class="draft-chip">{{ type }}</span>
        <span class="draft-chip">{{ target_format }}</span>
        {% if source_pdf %}<a class="draft-link" href="{{ source_pdf | previewRelativeUrl }}" target="_blank" rel="noopener">Altes PDF öffnen</a>{% endif %}
        <a class="draft-link primary" href="{{ '/handout-drafts/' | previewRelativeUrl }}">Alle Drafts</a>
      </div>
    </div>

    <div class="draft-paper">
      <header class="draft-header{% if type == 'Akutblatt' %} alert-mode{% endif %}">
        <div class="draft-kicker">
          {% if priority and show_priority_badge != false %}<span class="draft-badge">{{ priority }}</span>{% endif %}
          <span class="draft-badge{% if type == 'Akutblatt' %} alert{% endif %}">{{ type }}</span>
          {% if status and show_status_badge != false %}<span class="draft-badge">{{ status }}</span>{% endif %}
        </div>
        <h1 class="draft-title">{{ title }}</h1>
        <p class="draft-subtitle">{{ goal }}</p>
        <div class="draft-meta">
          <div class="draft-meta-card">
            <div class="draft-meta-label">Zielgruppe</div>
            <div class="draft-meta-value">{{ audience }}</div>
          </div>
          <div class="draft-meta-card">
            <div class="draft-meta-label">Stand</div>
            <div class="draft-meta-value">{{ last_updated | formatSwissDate }}</div>
          </div>
        </div>
        {% if emergency_callout or quick_steps %}
          <div class="draft-alert-panel" aria-label="Schnelle Orientierung">
            <div>
              {% if emergency_label %}<div class="draft-alert-eyebrow">{{ emergency_label }}</div>{% endif %}
              {% if emergency_callout %}<p class="draft-alert-line">{{ emergency_callout }}</p>{% endif %}
              {% if emergency_note %}<p class="draft-alert-copy">{{ emergency_note }}</p>{% endif %}
            </div>
            {% if quick_steps %}
              <div class="draft-quick-steps">
                {% for step in quick_steps %}
                  <div class="draft-step">
                    <div class="draft-step-index{% if step.icon %} icon{% endif %}{% if step.wide %} wide{% endif %}">{{ step.icon or loop.index }}</div>
                    <div class="draft-step-text">{{ step.text or step }}</div>
                  </div>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      </header>

      <main class="draft-content">
        {% if emergency_contacts %}
          <section class="draft-number-bar" aria-label="Wichtige Nummern">
            {% for item in emergency_contacts %}
              <div class="draft-number-card{% if item.tone == 'urgent' %} urgent{% endif %}">
                <div class="draft-number-label">{{ item.label }}</div>
                <div class="draft-number-value">{{ item.number }}</div>
                {% if item.note %}<div class="draft-number-note">{{ item.note }}</div>{% endif %}
              </div>
            {% endfor %}
          </section>
        {% endif %}
        {{ content | stripFirstH1 | previewRelativeHtml | safe }}
      </main>

      <footer class="draft-footer">
        <div>PUK Zürich · Handout-Draft-System</div>
        <div class="draft-footer-status">{{ slug }} · noch nicht final exportiert</div>
      </footer>
    </div>
  </div>
</body>
</html>
