<!DOCTYPE html>
<html lang="de"{% if noJs %} class="no-js"{% endif %}>
<head>
<meta charset="UTF-8">
{% if noJs %}<script>document.documentElement.classList.remove('no-js')</script>{% endif %}
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="icon" href="/favicon.png" type="image/png" sizes="32x32">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<link rel="manifest" href="/site.webmanifest">
<meta name="theme-color" content="#7a6f66">
<meta name="description" content="{{ description }}">
<title>{{ title }}</title>
{% if canonical %}<link rel="canonical" href="{{ canonical }}">
{% else %}<link rel="canonical" href="{{ site.url }}{{ page.url }}">
{% endif %}
{% if not noIndex %}
<meta property="og:locale" content="de_CH">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:title" content="{{ ogTitle | default(title) }}">
<meta property="og:description" content="{{ ogDescription | default(description) }}">
<meta property="og:image" content="{{ site.url }}/og-image.png">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ ogTitle | default(title) }}">
<meta name="twitter:description" content="{{ ogDescription | default(description) }}">
<meta name="twitter:image" content="{{ site.url }}/og-image.png">
{% endif %}
{% if noIndex or site.noIndexDeploy %}<meta name="robots" content="noindex">{% endif %}
<link rel="preload" as="font" href="/fonts/dm-sans-variable.woff2" type="font/woff2" crossorigin>
<link rel="preload" as="font" href="/fonts/dm-serif-display-400.woff2" type="font/woff2" crossorigin>
<link rel="stylesheet" href="/css/tokens.css?v=10">
<link rel="stylesheet" href="/fonts/fonts.css?v=10">
{% if useSharedCSS %}<link rel="stylesheet" href="/css/shared.css?v=10">{% endif %}
{% if useModuleCSS %}<link rel="stylesheet" href="/css/module.css?v=10">{% endif %}
{% if useToolCSS %}<link rel="stylesheet" href="/css/tools.css?v=10">{% endif %}
{% block headCSS %}{% endblock %}
<link rel="stylesheet" href="/css/print.css?v=10" media="print">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "Psychiatrische Universitätsklinik Zürich",
      "alternateName": "PUK Zürich",
      "url": "{{ site.url }}",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Lenggstrasse 31",
        "postalCode": "8032",
        "addressLocality": "Zürich",
        "addressCountry": "CH"
      },
      "telephone": "{{ site.tel.fachstelle.href | replace('tel:', '') }}",
      "department": {
        "@type": "Organization",
        "name": "Fachstelle Angehörigenarbeit"
      }
    },
    {
      "@type": "WebSite",
      "name": "Bipolare Störung — Psychoedukation für Angehörige",
      "url": "{{ site.url }}",
      "publisher": {
        "@type": "Organization",
        "name": "Fachstelle Angehörigenarbeit",
        "parentOrganization": { "@type": "Organization", "name": "Psychiatrische Universitätsklinik Zürich" }
      },
      "inLanguage": "de-CH"
    }{% if useModuleCSS or useToolCSS %},
    {
      "@type": "MedicalWebPage",
      "name": "{{ title }}",
      "description": "{{ description }}",
      "url": "{{ site.url }}{{ page.url }}",
      "inLanguage": "de-CH",
      "lastReviewed": "{{ page.inputPath | pageLastModified(site.lastReviewed) }}",
      "medicalAudience": {
        "@type": "MedicalAudience",
        "audienceType": "Caregiver",
        "healthCondition": {
          "@type": "MedicalCondition",
          "name": "Bipolare Störung",
          "alternateName": "Bipolar Disorder",
          "code": { "@type": "MedicalCode", "codeValue": "F31", "codingSystem": "ICD-10" }
        }
      },
      "specialty": {
        "@type": "MedicalSpecialty",
        "name": "Psychiatry"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Fachstelle Angehörigenarbeit",
        "parentOrganization": { "@type": "Organization", "name": "Psychiatrische Universitätsklinik Zürich" }
      }
    }{% endif %}{% if breadcrumbs %},
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Startseite",
          "item": "{{ site.url }}/"
        }{% for crumb in breadcrumbs %},
        {
          "@type": "ListItem",
          "position": {{ loop.index + 1 }},
          "name": "{{ crumb.name }}",
          "item": "{{ site.url }}{{ crumb.url }}"
        }{% endfor %}
      ]
    }{% endif %}
  ]
}
</script>
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}{% if moduleAccent %} data-module-accent="{{ moduleAccent }}"{% endif %}>
<a href="#main-content" class="skip-link">Direkt zum Inhalt</a>
{% block nav %}{% endblock %}
{% block content %}{{ content | safe }}{% endblock %}
{% block footer %}{% endblock %}
<button type="button" class="back-to-top" aria-label="Zurück nach oben" id="backToTop"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 15l-6-6-6 6"/></svg></button>
{% if useNavJS %}<script src="/js/nav.js"></script>{% endif %}
<script src="/js/base-ui.js"></script>
{% if useCombinedModuleUiJS %}
<script src="/js/module-page.js"></script>
{% else %}
{% if useModuleCSS and not skipModuleUiJS %}<script src="/js/module-ui.js"></script>{% endif %}
{% if usePdfPreviewJS %}<script src="/js/pdf-preview.js"></script>{% endif %}
{% endif %}
{% block scripts %}{% endblock %}
</body>
</html>
