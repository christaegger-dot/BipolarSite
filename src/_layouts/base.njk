<!DOCTYPE html>
<html lang="de"{% if noJs %} class="no-js"{% endif %}>
<head>
<meta charset="UTF-8">
{% if noJs %}<script>document.documentElement.classList.remove('no-js')</script>{% endif %}
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="icon" href="/favicon.png" type="image/png" sizes="32x32">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<meta name="theme-color" content="#1c2b3a">
<meta name="description" content="{{ description }}">
<title>{{ title }}</title>
{% if canonical %}<link rel="canonical" href="{{ canonical }}">
{% else %}<link rel="canonical" href="{{ site.url }}{{ page.url }}">
{% endif %}
{% if not noIndex %}
<meta property="og:locale" content="de_CH">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:title" content="{{ ogTitle | default(title) }}">
<meta property="og:description" content="{{ ogDescription | default(description) }}">
<meta property="og:image" content="{{ site.url }}/og-image.png">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ ogTitle | default(title) }}">
<meta name="twitter:description" content="{{ ogDescription | default(description) }}">
<meta name="twitter:image" content="{{ site.url }}/og-image.png">
{% endif %}
{% if noIndex or site.noIndexDeploy %}<meta name="robots" content="noindex">{% endif %}
<link rel="preload" as="font" href="/fonts/dm-sans-variable.woff2" type="font/woff2" crossorigin>
<link rel="preload" as="font" href="/fonts/dm-serif-display-400.woff2" type="font/woff2" crossorigin>
<link rel="stylesheet" href="/css/tokens.css?v=6">
<link rel="stylesheet" href="/fonts/fonts.css?v=6">
{% if useSharedCSS %}<link rel="stylesheet" href="/css/shared.css?v=6">{% endif %}
{% if useModuleCSS %}<link rel="stylesheet" href="/css/module.css?v=6">{% endif %}
{% if useToolCSS %}<link rel="stylesheet" href="/css/tools.css?v=6">{% endif %}
{% block headCSS %}{% endblock %}
<link rel="stylesheet" href="/css/overrides.css?v=6">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "Psychiatrische Universitätsklinik Zürich",
      "alternateName": "PUK Zürich",
      "url": "{{ site.url }}"
    },
    {
      "@type": "WebSite",
      "name": "Bipolare Störung — Psychoedukation für Angehörige",
      "url": "{{ site.url }}",
      "publisher": { "@type": "Organization", "name": "PUK Zürich" },
      "inLanguage": "de"
    }{% if useModuleCSS %},
    {
      "@type": "MedicalWebPage",
      "name": "{{ title }}",
      "description": "{{ description }}",
      "url": "{{ site.url }}{{ page.url }}",
      "inLanguage": "de",
      "medicalAudience": { "@type": "MedicalAudience", "audienceType": "Caregiver" },
      "publisher": { "@type": "Organization", "name": "PUK Zürich" }
    }{% endif %}
  ]
}
</script>
</head>
<body{% if moduleAccent %} data-module-accent="{{ moduleAccent }}"{% endif %}>
<a href="#main-content" class="skip-link">Direkt zum Inhalt</a>
{% block nav %}{% endblock %}
{% block content %}{{ content | safe }}{% endblock %}
{% block footer %}{% endblock %}
{% if useNavJS %}<script src="/js/nav.js"></script>{% endif %}
<script>
  try {
    if (localStorage.getItem('puk_storage_consent') === 'true') {
      const modulePath = window.location.pathname.match(/^\/modul\/\d+\/?$/);
      if (modulePath) {
        const key = 'puk_visited_modules';
        const normalized = modulePath[0].endsWith('/') ? modulePath[0] : `${modulePath[0]}/`;
        const visited = JSON.parse(localStorage.getItem(key) || '[]');
        if (Array.isArray(visited) && !visited.includes(normalized)) {
          visited.push(normalized);
          localStorage.setItem(key, JSON.stringify(visited));
        }
      }
    }
  } catch (error) { console.warn('Storage unavailable:', error.message); }

  document.querySelectorAll('[data-sources-toggle]').forEach((button, index) => {
    const section = button.closest('.sources');
    const list = section ? section.querySelector('ul') : null;
    if (!section || !list) return;

    if (!list.id) list.id = `sources-list-${index + 1}`;
    const isOpen = section.classList.contains('sources-open') || button.getAttribute('aria-expanded') === 'true';

    button.setAttribute('aria-controls', list.id);
    button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    section.classList.toggle('sources-open', isOpen);
    list.hidden = !isOpen;

    button.addEventListener('click', () => {
      const nextOpen = !section.classList.contains('sources-open');
      section.classList.toggle('sources-open', nextOpen);
      button.setAttribute('aria-expanded', nextOpen ? 'true' : 'false');
      list.hidden = !nextOpen;
    });
  });

  // Mobile TOC accordion
  if (window.innerWidth <= 768) {
    document.querySelectorAll('.toc').forEach(toc => {
      const ol = toc.querySelector('ol');
      if (!ol) return;
      ol.hidden = true;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'toc-mobile-toggle';
      btn.setAttribute('aria-expanded', 'false');
      btn.textContent = 'Inhaltsverzeichnis anzeigen ▾';
      toc.querySelector('.toc-title').after(btn);
      btn.addEventListener('click', () => {
        const open = ol.hidden;
        ol.hidden = !open;
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        btn.textContent = open ? 'Inhaltsverzeichnis ausblenden ▴' : 'Inhaltsverzeichnis anzeigen ▾';
      });
    });
  }

  // Desktop sticky TOC sidebar (modules only, ≥1100px)
  if (window.innerWidth >= 1100) {
    const tocOl = document.querySelector('.toc ol');
    const contentEl = document.querySelector('main.content');
    if (tocOl && contentEl) {
      const nav = document.createElement('nav');
      nav.className = 'toc-sidebar';
      nav.setAttribute('aria-label', 'Inhaltsverzeichnis');
      const ol = document.createElement('ol');
      tocOl.querySelectorAll('li > a').forEach(a => {
        const li = document.createElement('li');
        const link = document.createElement('a');
        link.href = a.getAttribute('href');
        link.textContent = a.childNodes[0].textContent.trim();
        li.appendChild(link);
        ol.appendChild(li);
      });
      nav.appendChild(ol);
      contentEl.parentNode.insertBefore(nav, contentEl);
      // Track active section
      const headings = Array.from(contentEl.querySelectorAll('h2[id]'));
      const sidebarLinks = Array.from(nav.querySelectorAll('a'));
      if (headings.length && sidebarLinks.length) {
        const observer = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              sidebarLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + id));
            }
          });
        }, { rootMargin: '-80px 0px -70% 0px' });
        headings.forEach(h => observer.observe(h));
      }
    }
  }

  // Expandable sections
  document.querySelectorAll('.expandable-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const more = btn.previousElementSibling;
      if (!more || !more.classList.contains('expandable-more')) return;
      const open = more.hidden;
      more.hidden = !open;
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      btn.textContent = open ? 'Weniger anzeigen ▴' : 'Weiterlesen ▾';
    });
  });
</script>
{% block scripts %}{% endblock %}
<script>if('serviceWorker' in navigator){navigator.serviceWorker.register('/sw.js').catch(function(){})}</script>
{% if not noStorageBanner %}
<div id="storageBanner" class="storage-banner" hidden role="status">
  <span>Fortschritt lokal speichern? Keine Daten werden gesendet.</span>
  <div class="storage-banner-btns">
    <button type="button" id="storageAccept" class="storage-btn-accept">Ja</button>
    <button type="button" id="storageDecline" class="storage-btn-decline">Nein</button>
  </div>
</div>
<script>
(function(){
  try {
    var consent = localStorage.getItem('puk_storage_consent');
    if (consent === 'true' || consent === 'false') return;
    var b = document.getElementById('storageBanner');
    if (b) b.hidden = false;
    document.getElementById('storageAccept').addEventListener('click', function(){
      try { localStorage.setItem('puk_storage_consent', 'true'); } catch(e){}
      b.hidden = true;
    });
    document.getElementById('storageDecline').addEventListener('click', function(){
      try { localStorage.setItem('puk_storage_consent', 'false'); } catch(e){}
      b.hidden = true;
    });
  } catch(e){}
})();
</script>
{% endif %}
</body>
</html>
