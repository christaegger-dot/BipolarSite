permalink: "/module/"
navCurrent: "module-overview"
useSharedCSS: true
useNavJS: true
footerAttribution: "Inhaltliche Verantwortung: Ch. Egger · Stand: April 2026"
---
{% block headCSS %}
<style>
  /* ── Page-specific: decorative blobs + colors ── */
  .overview-hero::before {
    top: -24%; right: -10%; width: 640px; height: 640px;
    background: none; display: none;
    opacity: 0.82;
  }
  .overview-hero::after {
    bottom: -18%; left: -6%; width: 520px; height: 520px;
    background: none; display: none;
    opacity: 0.78;
  }
  .overview-badge { background: rgba(221,210,191,0.34); color: var(--sand-deep); }
  .overview-intro { grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr); }
  .overview-note { background: #fff; }
  .overview-note p + p { margin-top: 10px; }
  .overview-section { padding-top: 8px; }
</style>
{% endblock %}

{% block nav %}
{% include "nav-full.njk" %}
{% endblock %}

{% block content %}
<header class="overview-hero">
  <div class="overview-hero-inner">
    <div class="overview-breadcrumb"><a href="/">Startseite</a><span>›</span><span>Module</span></div>
    <div class="overview-badge">Lernpfad</div>
    <h1>Die 8 Module im Überblick</h1>
    <p class="overview-lead">Hier finden Sie den vollständigen Lernpfad in einer eigenen Übersicht. Sie können die Module der Reihe nach lesen oder gezielt dort einsteigen, wo Ihre Lage im Moment am meisten Druck macht.</p>
  </div>
</header>

<main id="main-content" class="overview-content">
  <div class="overview-intro">
    <div class="overview-note">
      <h2>Wenn Sie Schritt für Schritt lesen möchten</h2>
      <p>Die Module 1 bis 7 bauen inhaltlich aufeinander auf: vom Verstehen über Belastung und Beziehungsdynamik bis zu konkreten Schritten und langfristiger Tragfähigkeit.</p>
      <p><strong>Modul 8</strong> ist zugleich Abschlussmodul und direkter Einstieg für Unterstützung, Materialien und nächste Schritte.</p>
    </div>
    <div class="overview-note">
      <h2>Wenn Sie sofort Orientierung brauchen</h2>
      <p><a href="/notfall/">Notfall &amp; Krise</a> hat Vorrang, wenn Gefahr oder starke Unsicherheit im Raum stehen. Für Beratungsstellen, Materialien und rechtliche Orientierung ist <a href="/modul/8/">Modul 8</a> der schnellste Einstieg.</p>
    </div>
  </div>

  <section class="overview-section">
    <div class="section-label">Lernpfad</div>
    <h2 class="section-title">Alle Module als eigener Überblick</h2>
    <p class="section-desc">Jedes Modul steht für einen klaren Schwerpunkt. Wenn Sie nicht linear lesen möchten, wählen Sie zuerst den Bereich, der Ihre aktuelle Lage am besten trifft.</p>

    <div class="progress-bar" id="overviewProgressBar" hidden>
      <div class="progress-bar-header">
        <span class="progress-bar-label">Ihr Fortschritt</span>
        <span class="progress-bar-count" id="overviewProgressCount"></span>
      </div>
      <div class="progress-bar-track">
        <div class="progress-bar-fill" id="overviewProgressFill"></div>
      </div>
    </div>

    <div class="modules-grid">
      <a href="/modul/1/" class="module-card" data-accent="blue">
        <span class="module-number">Modul 1</span>
        <h3>Die bipolare Störung verstehen</h3>
        <p>Was die Erkrankung ist, wie sich Episoden zeigen und warum Angehörige oft mit Unsicherheit statt mit Klarheit leben.</p>
        <div class="module-card-footer">
          <span class="module-time">⏱ 10–12 Min.</span>
          <span class="module-arrow">→</span>
        </div>
      </a>

      <a href="/modul/2/" class="module-card" data-accent="amber">
        <span class="module-number">Modul 2</span>
        <h3>Was das mit Ihnen macht</h3>
        <p>Eigene Belastung, Hypervigilanz und die oft unsichtbaren Folgen des Lebens als Angehörige*r einer bipolaren Störung.</p>
        <div class="module-card-footer">
          <span class="module-time">⏱ 8–10 Min.</span>
          <span class="module-arrow">→</span>
        </div>
      </a>

      <a href="/modul/3/" class="module-card" data-accent="purple">
        <span class="module-number">Modul 3</span>
        <h3>Wie Beziehungen unter Druck geraten</h3>
        <p>Rollenverschiebung, Beziehungslogik, Vertrauensbrüche und die Frage, was Episoden in Beziehungen hinterlassen.</p>
        <div class="module-card-footer">
          <span class="module-time">⏱ 8–10 Min.</span>
          <span class="module-arrow">→</span>
        </div>
      </a>

      <a href="/modul/4/" class="module-card" data-accent="amber">
        <span class="module-number">Modul 4</span>
        <h3>Wenn die Kraft nachlässt</h3>
        <p>Schleichende Erschöpfung, ungreifbarer Verlust und die Frage, was chronische Belastung mit Angehörigen macht.</p>
        <div class="module-card-footer">
          <span class="module-time">⏱ 14–16 Min.</span>
          <span class="module-arrow">→</span>
        </div>
      </a>

      <a href="/modul/5/" class="module-card" data-accent="amber">
        <span class="module-number">Modul 5</span>
        <h3>Loyalitätskonflikte und schwierige Entscheidungen</h3>
        <p>Das Spannungsfeld zwischen Verpflichtung und Selbstschutz — mit Schuld, Grenzenot, Isolation und der Frage nach Abstand oder Neuordnung.</p>
        <div class="module-card-footer">
          <span class="module-time">⏱ 14–16 Min.</span>
          <span class="module-arrow">→</span>
        </div>
      </a>

      <a href="/modul/6/" class="module-card" data-accent="green">
        <span class="module-number">Modul 6</span>
        <h3>Was Sie konkret tun können</h3>
        <p>Gespräche, Grenzsetzung, Krisenplan und praktische Hilfen für belastende oder instabile Situationen.</p>
        <div class="module-card-footer">
          <span class="module-time">⏱ 10–12 Min.</span>
          <span class="module-arrow">→</span>
        </div>
      </a>

      <a href="/modul/7/" class="module-card" data-accent="green">
        <span class="module-number">Modul 7</span>
        <h3>Langfristige Tragfähigkeit</h3>
        <p>Selbstfürsorge stärken, Stabilität im Alltag sichern und die lange Strecke etwas tragfähiger machen.</p>
        <div class="module-card-footer">
          <span class="module-time">⏱ 12–14 Min.</span>
          <span class="module-arrow">→</span>
        </div>
      </a>

      <a href="/modul/8/" class="module-card" data-accent="teal">
        <span class="module-number">Modul 8</span>
        <h3>Unterstützung und Ressourcen</h3>
        <p>Abschlussmodul und direkter Ressourcen-Einstieg: Orientierung nach Situation, Anlaufstellen, Materialien und konkrete nächste Schritte.</p>
        <div class="module-card-footer">
          <span class="module-time">⏱ Schnellstart 3–5 Min.</span>
          <span class="module-arrow">→</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Progress Dashboard — next step suggestion -->
  <div class="progress-dashboard" id="progressDashboard" hidden>
    <div id="progressNext" hidden>
      <span class="progress-label">Nächster empfohlener Schritt: </span>
      <a id="progressNextLink" href="/modul/1/" class="progress-link"></a>
    </div>
  </div>

  <p class="overview-footer-note">Wenn Sie lieber interaktive Hilfen nutzen möchten, finden Sie auf der separaten Übersicht <a href="/werkzeuge/">alle Werkzeuge im Überblick</a>.</p>
</main>

<script>
(function() {
  var TITLES = {1:'Die bipolare Störung verstehen',2:'Was das mit Ihnen macht',3:'Wie Beziehungen unter Druck geraten',4:'Wenn die Kraft nachlässt',5:'Loyalitätskonflikte',6:'Was Sie konkret tun können',7:'Langfristige Tragfähigkeit',8:'Unterstützung und Ressourcen'};
  try {
    if (localStorage.getItem('puk_storage_consent') !== 'true') return;
    var visited = JSON.parse(localStorage.getItem('puk_visited_modules') || '[]');
    var visitedNums = visited.map(function(p) { var m = p.match(/\d+/); return m ? parseInt(m[0]) : 0; }).filter(Boolean);
    if (!visitedNums.length) return;

    // Progress bar
    var bar = document.getElementById('overviewProgressBar');
    var fill = document.getElementById('overviewProgressFill');
    var count = document.getElementById('overviewProgressCount');
    if (bar && fill && count) {
      bar.hidden = false;
      var pct = Math.round((visitedNums.length / 8) * 100);
      count.textContent = visitedNums.length + ' von 8 Modulen';
      fill.style.width = pct + '%';
    }

    // Mark visited cards
    document.querySelectorAll('a.module-card[href]').forEach(function(card) {
      var href = card.getAttribute('href');
      var m = href.match(/\/modul\/(\d+)/);
      if (m && visitedNums.indexOf(parseInt(m[1])) !== -1) {
        card.classList.add('visited');
        var arrow = card.querySelector('.module-arrow');
        if (arrow && arrow.textContent.trim() === '\u2192') arrow.textContent = '\u2713';
      }
    });

    // Next step
    var next = [1,2,3,4,5,6,7,8].filter(function(n) { return visitedNums.indexOf(n) === -1; })[0];
    if (next) {
      var dashboard = document.getElementById('progressDashboard');
      var el = document.getElementById('progressNext');
      var link = document.getElementById('progressNextLink');
      if (dashboard && el && link) {
        dashboard.hidden = false;
        el.hidden = false;
        link.href = '/modul/' + next + '/';
        link.textContent = 'Modul ' + next + ': ' + TITLES[next] + ' \u2192';
      }
    }
  } catch(e) { console.warn('Progress:', e.message); }
})();
</script>
{% endblock %}

