permalink: /js/tool-solidaritaets-chart.js
eleventyExcludeFromCollections: true
---
(() => {
  const episodes = [
    { name: 'Hypomanie', col: 'var(--amber)', bg: 'rgba(196,147,59,0.1)', impact: 'Leicht–Mittel', bel: 'Die Belastungsreserve sinkt oft zunächst nur leicht. Gerade das macht Hypomanie für Angehörige schwer lesbar: Viel wirkt noch produktiv oder charmant, gleichzeitig werden Schlaf, Reizbarkeit und Unsicherheit grösser.', stim: 'Die Stimmung steigt an — mehr Energie, weniger Schlaf, grössere Ideen. Für Angehörige bleibt oft unklar, ob es noch eine gute Phase ist oder schon der Beginn einer Episode.' },
    { name: 'Schwere Manie', col: 'var(--alert)', bg: 'rgba(199,84,80,0.1)', impact: 'Hoch', bel: 'Die Belastungsreserve bricht deutlich ein. Sicherheit, Geld, Konflikte, Kontrollverlust und Schlafentzug kommen oft gleichzeitig. Nach einer schweren Manie fühlt sich Erholung selten wie ein echter Neustart an.', stim: 'Der Ausschlag nach oben wird extrem: Grössenideen, Impulsivität, Gereiztheit, möglicherweise Psychose. Professionelle Intervention oder Hospitalisation ist häufig nötig.' },
    { name: 'Lange Depression', col: 'var(--blue-phase)', bg: 'rgba(91,127,165,0.1)', impact: 'Mittel–Hoch', bel: 'Die Belastungsreserve sinkt langsamer, aber stetig. Gerade diese schleichende Form wird oft unterschätzt: wenig sichtbare Dramatik, aber hohe Langzeitlast, Monotonie und innere Ausdünnung.', stim: 'Die Stimmung bleibt über Wochen oder Monate tief. Rückzug, Hoffnungslosigkeit, verlangsamter Alltag und Suizidgedanken können Angehörige auf andere Weise zermürben als eine Manie.' },
  ];

  const detail = document.getElementById('detail');
  const toggleButton = document.getElementById('toggleBtn');
  const supportLegend = document.getElementById('legSupport');
  const supportCurve = document.getElementById('curveSup');
  if (!detail || !toggleButton || !supportLegend || !supportCurve) return;

  const episodeButtons = document.querySelectorAll('.ep-btn');
  const episodeRects = [0, 1, 2].map((index) => document.getElementById(`ep${index}`));
  let activeEpisode = null;
  let showSupport = false;

  const render = () => {
    episodeButtons.forEach((button, index) => {
      const isActive = activeEpisode === index;
      button.classList.toggle('active', isActive);
      button.style.background = isActive ? episodes[index].col : 'var(--card)';
      button.style.color = isActive ? 'var(--cta-primary-text)' : 'var(--slate)';
      button.style.borderColor = isActive ? episodes[index].col : 'var(--border-warm)';
      button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    });

    episodeRects.forEach((rect, index) => {
      if (!rect) return;
      rect.setAttribute('fill', activeEpisode === index ? episodes[index].bg : 'rgba(0,0,0,0.02)');
    });

    if (activeEpisode !== null) {
      const episode = episodes[activeEpisode];
      detail.className = 'detail vis';
      detail.innerHTML = `<h2>${episode.name} <span style="font-size:var(--text-xs);font-weight:600;color:${episode.col};background:${episode.bg};padding:2px 8px;border-radius:var(--radius-sm);margin-left:8px">Belastung: ${episode.impact}</span></h2>
        <div class="detail-grid"><div class="detail-col" style="background:var(--amber-bg)"><h3 style="color:var(--amber)">Belastungsreserve</h3><p style="color:var(--slate)">${episode.bel}</p></div><div class="detail-col" style="background:var(--blue-phase-light)"><h3 style="color:var(--blue-phase)">Stimmung</h3><p style="color:var(--slate)">${episode.stim}</p></div></div>`;
    } else {
      detail.className = 'detail';
    }
  };

  const selectEpisode = (index) => {
    activeEpisode = activeEpisode === index ? null : index;
    render();
  };

  const toggleSupportView = () => {
    showSupport = !showSupport;
    supportCurve.setAttribute('opacity', showSupport ? '1' : '0');
    toggleButton.classList.toggle('on', showSupport);
    toggleButton.setAttribute('aria-pressed', showSupport ? 'true' : 'false');
    toggleButton.textContent = showSupport ? 'Entlastungsvergleich ausblenden' : 'Mit Entlastung vergleichen';
    supportLegend.style.display = showSupport ? 'flex' : 'none';
  };

  [0, 1, 2].forEach((index) => {
    const rect = document.getElementById(`ep${index}`);
    if (rect) rect.addEventListener('click', () => selectEpisode(index));
  });

  document.querySelector('.episodes')?.addEventListener('click', (event) => {
    const button = event.target.closest('.ep-btn[data-ep]');
    if (button) selectEpisode(Number(button.dataset.ep));
  });

  toggleButton.addEventListener('click', toggleSupportView);
})();
