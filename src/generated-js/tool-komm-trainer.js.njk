permalink: /js/tool-komm-trainer.js
eleventyExcludeFromCollections: true
---
(() => {
  const situations = [
    {
      ph: 'manie',
      pl: 'Manie',
      sit: 'Ihr Partner redet seit einer Stunde ohne Pause, springt von Thema zu Thema und wird immer aufgeregter.',
      opts: [
        {
          t: '«Kannst du bitte mal zuhören? Ich versuche dir seit einer Stunde zu erklären, dass…»',
          ok: false,
          fb: 'Lange Erklärungen und die Aufforderung zuzuhören funktionieren in der Manie nicht — das Gehirn kann es physisch nicht. Das eskaliert die Situation.',
        },
        {
          t: '«Mir fällt auf, dass du heute sehr viel Energie hast. Lass uns morgen darüber reden.»',
          ok: true,
          fb: 'Kurz, eine Beobachtung, kein Vorwurf — und ein klarer Zeitpunkt. In der Manie gilt: ein Satz, ein Thema, dann Pause.',
        },
      ],
    },
    {
      ph: 'depression',
      pl: 'Depression',
      sit: 'Ihr Partner liegt seit drei Tagen im Bett, reagiert kaum und sagt: «Es hat alles keinen Sinn.»',
      opts: [
        {
          t: '«Ich bin da. Du musst jetzt nichts sagen. Ich setze mich kurz zu dir.»',
          ok: true,
          fb: 'Stille Präsenz ist in der Depression wertvoller als jedes Wort. Sie signalisieren: Ich halte das aus. Du musst nichts leisten.',
        },
        {
          t: '«Du musst mal aufstehen und an die frische Luft — das wird dir guttun!»',
          ok: false,
          fb: 'Gut gemeint, aber kontraproduktiv. Ihr Partner würde aufstehen, wenn er könnte. «Du musst» erzeugt Druck und verstärkt die Scham.',
        },
      ],
    },
    {
      ph: 'manie',
      pl: 'Manie',
      sit: 'Ihr Partner hat über Nacht für CHF 3\'000 Online-Käufe getätigt und sagt: «Das sind Investitionen!»',
      opts: [
        {
          t: '«Du gibst schon wieder unser ganzes Geld aus! Das ist jedes Mal dasselbe!»',
          ok: false,
          fb: 'Vorwurf + «schon wieder» + «jedes Mal» — das ist der EE-Kreislauf in Reinform. Eskaliert sofort, ändert nichts.',
        },
        {
          t: '«Ich mache mir Sorgen über die Ausgaben. Ich rufe morgen die Bank an. Jetzt gehen wir schlafen.»',
          ok: true,
          fb: 'Ich-Botschaft, konkrete Massnahme, klare Grenze — ohne Eskalation. Die Manie lässt sich nicht wegdiskutieren.',
        },
      ],
    },
    {
      ph: 'depression',
      pl: 'Depression',
      sit: 'Ihr Partner sagt unter Tränen: «Ich bin eine Last für euch alle. Ihr wärt besser dran ohne mich.»',
      opts: [
        {
          t: '«Quatsch! Du bist doch keine Last! Denk mal an alles, was wir zusammen haben.»',
          ok: false,
          fb: 'Der Impuls ist verständlich — aber «Quatsch» entwertet das Gefühl. Ihr Partner fühlt sich nicht gehört, sondern korrigiert.',
        },
        {
          t: '«Ich verstehe, dass es sich so anfühlt. Du bist mir wichtig — gerade jetzt.»',
          ok: true,
          fb: 'Das Gefühl stehen lassen, ohne es zu bestätigen. Gleichzeitig Zuneigung zeigen. Sie dürfen das Gefühl halten.',
        },
      ],
    },
    {
      ph: 'manie',
      pl: 'Manie',
      sit: 'Ihr Partner schreit Sie an, weil Sie seinen «genialen Geschäftsplan» nicht unterstützen. Die Situation eskaliert.',
      opts: [
        {
          t: '«Ich lasse mich nicht anschreien. Ich gehe jetzt ins Nebenzimmer. Wenn wir ruhig reden können, komme ich zurück.»',
          ok: true,
          fb: 'Grenze + Konsequenz + Rückkehr-Signal. Sie schützen sich, ohne die Beziehung abzubrechen.',
        },
        {
          t: '«Wenn du so weitermachst, gehe ich! Dann kannst du sehen, wie du alleine klarkommst!»',
          ok: false,
          fb: 'Drohungen werden in der Manie nicht ernst genommen — oder sie eskalieren massiv. Eine Drohung ist keine Grenze.',
        },
      ],
    },
    {
      ph: 'depression',
      pl: 'Depression',
      sit: 'Seit Wochen kaum Besserung. Sie haben alles versucht — reden, kochen, Spaziergänge vorschlagen. Nichts hilft.',
      opts: [
        {
          t: 'Immer neue Vorschläge machen: «Hast du es schon mit Yoga probiert? Oder vielleicht Johanniskraut?»',
          ok: false,
          fb: 'Jeder neue Vorschlag signalisiert: Was du tust, reicht nicht. Sie sind nicht die Therapie — Ihre Anwesenheit reicht.',
        },
        {
          t: '«Ich kann das nicht lösen. Aber ich bin hier. Und ich gehe nirgendwo hin.»',
          ok: true,
          fb: 'Dieser Satz entlastet Sie beide. Sie von der Verantwortung, alles zu reparieren. Ihren Partner vom Druck, sich «zusammenzureissen».',
        },
      ],
    },
    {
      ph: 'frueh',
      pl: 'Frühwarnung',
      sit: 'Sie bemerken seit einigen Tagen, dass Ihr Partner weniger schläft als sonst, lebhafter wirkt und schneller redet. Er selbst sieht kein Problem.',
      opts: [
        {
          t: '«Ich glaube, du wirst wieder manisch. Ich rufe sofort deinen Arzt an.»',
          ok: false,
          fb: 'Der direkte Alarmton erzeugt Abwehr. In der Frühwarnphase ist der Spielraum für Kooperation noch da — diesen sollten Sie nutzen, bevor er sich schliesst.',
        },
        {
          t: '«Mir fällt auf, dass du die letzten drei Nächte weniger geschlafen hast. Magst du das auch wahrnehmen?»',
          ok: true,
          fb: 'Beobachtung ohne Anklage, Einbeziehung statt Überfahren. In der Frühwarnphase ist das Ziel: die Person einladen, selbst hinzuschauen — nicht überzeugen, dass etwas falsch ist.',
        },
      ],
    },
    {
      ph: 'nach',
      pl: 'Nach der Krise',
      sit: 'Die manische Episode liegt drei Wochen zurück. Ihr Partner ist stabil. Sie tragen noch verletzende Aussagen und Situationen aus der Krise mit sich.',
      opts: [
        {
          t: '«Wir müssen jetzt alles aufarbeiten. Du musst verstehen, was du mir angetan hast.»',
          ok: false,
          fb: 'Der Wunsch nach Aufarbeitung ist verständlich — aber «du musst» und «alles» erzeugen Druck. In der Nachphase braucht es einen behutsamen Einstieg, keinen konfrontativen.',
        },
        {
          t: '«Ich trage noch einige Dinge aus letztem Monat mit mir. Ich fände es gut, wenn wir dafür irgendwann einen Moment finden — wenn du bereit bist.»',
          ok: true,
          fb: 'Ehrlich über das eigene Tragen, ohne Anklage. Das «wenn du bereit bist» gibt Kontrolle zurück. Beides ist möglich: die Episode war krankheitsbedingt — und das Erlebte war verletzend.',
        },
      ],
    },
  ];

  const progress = document.getElementById('prog');
  const card = document.getElementById('card');
  if (!progress || !card) return;

  let currentIndex = 0;
  let selected = null;
  let score = { ok: 0, total: 0 };
  let finished = false;

  const shuffledOptions = situations.map((situation) =>
    Math.random() > 0.5 ? [...situation.opts] : [...situation.opts].reverse()
  );

  const render = () => {
    progress.innerHTML = situations
      .map((_, index) => `<div class="${index < score.total ? 'done' : index === currentIndex && !finished ? 'cur' : ''}"></div>`)
      .join('');

    if (!finished) {
      const situation = situations[currentIndex];
      const opts = shuffledOptions[currentIndex];

      card.innerHTML = `<div class="card-body"><div class="phase-row"><div class="phase-badge phase-${situation.ph[0]}">${situation.pl}</div><span class="phase-count">Situation ${currentIndex + 1} / ${situations.length}</span></div><p class="sit">${situation.sit}</p><div class="olbl">Wie reagieren Sie?</div>
        ${opts
          .map((option, index) => {
            const revealed = selected !== null;
            const isSelected = selected === index;
            const isCorrect = option.ok;
            let className = 'opt-btn';

            if (revealed) {
              if (isCorrect) className += ' correct';
              else if (isSelected && !isCorrect) className += ' wrong';
              else className += ' dimmed';
            }

            let html = `<button class="${className}" ${revealed ? 'disabled' : ''} data-pick="${index}"><span class="mark">${revealed ? (isCorrect ? '✓' : '✗') : ''}</span>${option.t}</button>`;
            if (revealed && (isSelected || isCorrect)) html += `<div class="fb ${isCorrect ? 'fb-ok' : 'fb-no'}">${option.fb}</div>`;
            return html;
          })
          .join('')}
        ${selected !== null ? `<button class="btn-next" data-action="nx">${currentIndex < situations.length - 1 ? 'Nächste Situation →' : 'Auswertung →'}</button>` : ''}
      </div>`;
      return;
    }

    const percent = Math.round((score.ok / situations.length) * 100);
    const color = percent >= 80 ? 'var(--phase-green)' : percent >= 50 ? 'var(--amber)' : 'var(--amber-dark-text)';
    const background = percent >= 80 ? 'var(--success-soft)' : percent >= 50 ? 'var(--amber-bg)' : 'var(--alert-soft)';

    card.innerHTML = `<div class="res"><div class="res-circle" style="background:${background};border-color:${color}"><span style="color:${color}">${score.ok}/${situations.length}</span></div>
      <h2>${percent >= 80 ? 'Sie haben ein gutes Gespür für die Unterschiede.' : percent >= 50 ? 'Eine brauchbare Basis ist da — mit Übung wird es klarer.' : 'Kommunikation unter Druck ist schwer — genau dafür ist diese Übung da.'}</h2>
      <p>${percent >= 80 ? 'Sie erkennen recht gut, warum Manie und Depression unterschiedliche Sprache brauchen.' : 'Die Situationen sind absichtlich schwer — im echten Leben bleibt oft kaum Zeit. Entscheidend sind nicht perfekte Sätze, sondern die Grundrichtung.'}</p>
      <div class="rules"><div class="rules-title">Die zwei Grundregeln</div><p><strong>Manie:</strong> Kurz, klar, ein Thema. Nicht argumentieren. Rausgehen, wenn es eskaliert.</p><p><strong>Depression:</strong> Stille Präsenz. Nicht aufmuntern. Gefühle stehen lassen, nicht korrigieren.</p></div>
      <div class="btns"><button class="btn-r" data-action="rs">Erneut üben</button><button class="btn-c" data-action="nav" data-href="/modul/6/">Zurück zu Modul 6 →</button></div></div>`;
  };

  const pick = (index) => {
    if (selected !== null) return;
    selected = index;
    const option = shuffledOptions[currentIndex][index];
    score.ok += option.ok ? 1 : 0;
    score.total += 1;
    render();
  };

  const next = () => {
    selected = null;
    if (currentIndex < situations.length - 1) currentIndex += 1;
    else finished = true;
    render();
  };

  const reset = () => {
    currentIndex = 0;
    selected = null;
    score = { ok: 0, total: 0 };
    finished = false;
    render();
  };

  render();

  document.addEventListener('click', (event) => {
    const pickButton = event.target.closest('[data-pick]');
    if (pickButton && !pickButton.disabled) {
      pick(Number(pickButton.dataset.pick));
      return;
    }

    const actionButton = event.target.closest('[data-action]');
    if (!actionButton || actionButton.disabled) return;

    if (actionButton.dataset.action === 'nx') next();
    else if (actionButton.dataset.action === 'rs') reset();
    else if (actionButton.dataset.action === 'nav') window.location.assign(actionButton.dataset.href);
  });
})();
