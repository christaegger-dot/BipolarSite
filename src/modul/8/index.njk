<script>
  const pb=document.getElementById('readingProgress');window.addEventListener('scroll',()=>{const h=document.documentElement.scrollHeight-window.innerHeight;pb.style.width=h>0?(window.scrollY/h*100)+'%':'0%'});
  const tocLinks=document.querySelectorAll('.toc a[href^="#"]');const tocSections=Array.from(tocLinks).map(a=>{const id=a.getAttribute('href').slice(1);return{link:a,el:document.getElementById(id)}}).filter(s=>s.el);const tocObs=new IntersectionObserver((entries)=>{entries.forEach(e=>{if(e.isIntersecting){tocLinks.forEach(l=>l.classList.remove('active'));const match=tocSections.find(s=>s.el===e.target);if(match)match.link.classList.add('active')}})},{threshold:0.1,rootMargin:'-100px 0px -60% 0px'});tocSections.forEach(s=>tocObs.observe(s.el));
  const MATERIAL_FINDER={akut:[{kicker:'Jetzt zuerst',title:'Notfallseite öffnen',text:'Wenn Gefahr oder starke Unsicherheit im Raum stehen, ist die Triage wichtiger als die ganze Materialsammlung.',href:'/notfall/',label:'Zum Notfallweg →'},{kicker:'PDF',title:'Notfallkarte Kanton Zürich',text:'Alle wichtigen Nummern mit kurzer Einordnung, wann welche Stelle sinnvoll ist.',href:'/downloads/notfallkarte-kanton-zuerich-puk.pdf',label:'Notfallkarte herunterladen →'},{kicker:'Danach',title:'Krisenplan bereithalten',text:'Wenn schon einer existiert, jetzt hervornehmen. Wenn nicht, später in ruhiger Phase vorbereiten.',href:'/modul/6/',label:'Zu Modul 6 →'}],plan:[{kicker:'PDF',title:'Krisenplan-Vorlage',text:'Die wichtigste Unterlage, wenn Sie Frühwarnzeichen, Kontakte und Klinikwünsche vorab ordnen möchten.',href:'/downloads/krisenplan-vorlage-bipolare-stoerung-puk-zuerich.pdf',label:'Krisenplan herunterladen →'},{kicker:'Werkzeug',title:'Krisenplan-Werkzeug',text:'Wenn Sie den Plan lieber direkt am Bildschirm vorbereiten und danach drucken möchten.',href:'/tools/krisenplan/',label:'Werkzeug öffnen →'},{kicker:'Vertiefung',title:'Modul 6: konkrete Schritte',text:'Für Gespräche, Grenzen, Krisenplan und Vorbereitung in stabilen Phasen.',href:'/modul/6/',label:'Zu Modul 6 →'}],ersch:[{kicker:'Archiv-Handout',title:'Trauer ohne klaren Abschied',text:'Hilft, schleichende Erschöpfung, Trauer und Selbstverlust besser zu verstehen. Dieses Blatt gehört noch zum älteren PDF-Bestand.',href:'/handouts/a4_ambiguous_loss.pdf',label:'Handout öffnen →'},{kicker:'PDF',title:'Was stabilisiert — was schadet',text:'Ein kompaktes Blatt für Alltag, Selbstfürsorge und kleine entlastende Schritte.',href:'/downloads/kurzblatt-was-stabilisiert-was-schadet-puk-zuerich.pdf',label:'Kurzblatt herunterladen →'},{kicker:'Kontakt',title:'Selbsthilfe oder Angehörigenberatung',text:'Wenn Information allein nicht mehr reicht, ist Resonanz oft der entlastendere nächste Schritt.',href:'#anlaufstellen',label:'Zu den Anlaufstellen →'}],recht:[{kicker:'Kontakt',title:'Pro Mente Sana',text:'Psychosoziale und juristische Beratung zu FU, Vorsorgeauftrag, Patientenverfügung und Konflikten mit Institutionen.',href:'https://www.promentesana.ch',label:'Pro Mente Sana öffnen →'},{kicker:'Kontakt',title:'Ombudsstelle Krankenversicherung',text:'Wenn Leistungsstreitigkeiten oder abgelehnte Kostengutsprachen blockieren.',href:'https://om-kv.ch',label:'Ombudsstelle öffnen →'},{kicker:'Orientierung',title:'Systemblockaden einordnen',text:'Wenn das Versorgungssystem zusätzlich belastet, hilft oft zuerst die Klärung der Beschwerde- und Beratungswege.',href:'#system',label:'Zum System-Abschnitt →'}]};
  const materialFinderButtons=document.querySelectorAll('[data-material-finder]');
  const materialFinderResults=document.getElementById('materialFinderResults');
  const renderMaterialFinder=(key)=>{const items=MATERIAL_FINDER[key];if(!items||!materialFinderResults)return;materialFinderButtons.forEach(btn=>{const isActive=btn.dataset.materialFinder===key;btn.classList.toggle('is-active',isActive);btn.setAttribute('aria-pressed',isActive?'true':'false');});materialFinderResults.innerHTML=items.map(item=>`<div class="finder-card"><div class="finder-card-kicker">${item.kicker}</div><h4>${item.title}</h4><p>${item.text}</p><a href="${item.href}"${item.href.startsWith('http')?' target="_blank" rel="noopener"':''}${item.href.startsWith('/downloads/')?' download':''}>${item.label}</a></div>`).join('');materialFinderResults.hidden=false;materialFinderResults.querySelectorAll('a[href$=".pdf"]').forEach(setupPdfPreviewLink);};
  materialFinderButtons.forEach(button=>{button.addEventListener('click',()=>renderMaterialFinder(button.dataset.materialFinder));});
  const MINI_PLAN_KEY='puk_modul8_mini_plan';
  const miniPlanNumber=document.getElementById('miniPlanNumber');
  const miniPlanDocument=document.getElementById('miniPlanDocument');
  const miniPlanStep=document.getElementById('miniPlanStep');
  const miniPlanSave=document.getElementById('miniPlanSave');
  const miniPlanClear=document.getElementById('miniPlanClear');
  const miniPlanStatus=document.getElementById('miniPlanStatus');
  const miniPlanSummary=document.getElementById('miniPlanSummary');
  const miniPlanSummaryNumber=document.getElementById('miniPlanSummaryNumber');
  const miniPlanSummaryDocument=document.getElementById('miniPlanSummaryDocument');
  const miniPlanSummaryStep=document.getElementById('miniPlanSummaryStep');
  const readMiniPlan=()=>{try{return JSON.parse(localStorage.getItem(MINI_PLAN_KEY)||'null')}catch{return null}};
  const writeMiniPlan=(data)=>{try{localStorage.setItem(MINI_PLAN_KEY,JSON.stringify(data));return true}catch{return false}};
  const clearMiniPlanStorage=()=>{try{localStorage.removeItem(MINI_PLAN_KEY)}catch{}};
  const renderMiniPlanSummary=(data)=>{
    if(!data||(!data.number&&!data.document&&!data.step)){miniPlanSummary.hidden=true;miniPlanSummaryNumber.textContent='—';miniPlanSummaryDocument.textContent='—';miniPlanSummaryStep.textContent='—';return;}
    miniPlanSummary.hidden=false;
    miniPlanSummaryNumber.textContent=data.number||'—';
    miniPlanSummaryDocument.textContent=data.document||'—';
    miniPlanSummaryStep.textContent=data.step||'—';
  };
  const loadMiniPlan=()=>{
    const saved=readMiniPlan();
    if(!saved)return;
    miniPlanNumber.value=saved.number||'';
    miniPlanDocument.value=saved.document||'';
    miniPlanStep.value=saved.step||'';
    renderMiniPlanSummary(saved);
    miniPlanStatus.textContent='Ihr zuletzt gespeicherter Mini-Plan wurde geladen.';
  };
  miniPlanSave.addEventListener('click',()=>{
    const data={number:miniPlanNumber.value.trim(),document:miniPlanDocument.value,step:miniPlanStep.value.trim()};
    if(!data.number&&!data.document&&!data.step){miniPlanStatus.textContent='Bitte zuerst mindestens ein Feld ausfüllen.';renderMiniPlanSummary(null);return;}
    if(writeMiniPlan(data)){miniPlanStatus.textContent='Mini-Plan lokal auf diesem Gerät gespeichert.';renderMiniPlanSummary(data);}
    else{miniPlanStatus.textContent='Speichern war in diesem Browser gerade nicht möglich.';}
  });
  miniPlanClear.addEventListener('click',()=>{
    miniPlanNumber.value='';miniPlanDocument.value='';miniPlanStep.value='';clearMiniPlanStorage();renderMiniPlanSummary(null);miniPlanStatus.textContent='Mini-Plan von diesem Gerät gelöscht.';
  });
  loadMiniPlan();
  const pdfPreview=document.getElementById('pdf-preview');
  const pdfPreviewFrame=document.getElementById('pdf-preview-frame');
  const pdfPreviewTitle=document.getElementById('pdf-preview-title');
  const pdfPreviewOpen=document.getElementById('pdf-preview-open');
  const pdfPreviewDownload=document.getElementById('pdf-preview-download');
  const pdfPreviewClose=document.getElementById('pdf-preview-close');
  const pdfPreviewDialog=pdfPreview.querySelector('.pdf-preview-dialog');
  const FOCUSABLE_SELECTOR='a[href],button:not([disabled]),textarea:not([disabled]),input:not([disabled]),select:not([disabled]),[tabindex]:not([tabindex="-1"])';
  let pdfPreviewTrigger=null;

  const setPageInert=(isInert)=>{[...document.body.children].filter(el=>el!==pdfPreview).forEach(el=>{el.inert=isInert})};
  const trapFocus=(event,container)=>{
    if(event.key!=='Tab')return;
    const focusable=[...container.querySelectorAll(FOCUSABLE_SELECTOR)].filter(el=>!el.hidden&&el.offsetParent!==null);
    if(!focusable.length){event.preventDefault();container.focus();return}
    const first=focusable[0];
    const last=focusable[focusable.length-1];
    if(event.shiftKey&&document.activeElement===first){event.preventDefault();last.focus()}
    else if(!event.shiftKey&&document.activeElement===last){event.preventDefault();first.focus()}
  };

  const getPdfTitle=(link)=>{
    const scopedTitle=link.querySelector('.handout-card-title,.hc-title,.guide-title,.dl-body h4');
    if(scopedTitle)return scopedTitle.textContent.trim();
    return link.textContent.replace(/\s+/g,' ').replace(/^↓\s*PDF:\s*/i,'').trim()||'PDF-Vorschau';
  };

  const closePdfPreview=()=>{
    pdfPreview.hidden=true;
    document.body.classList.remove('pdf-preview-open');
    setPageInert(false);
    pdfPreviewFrame.src='about:blank';
    if(pdfPreviewTrigger)pdfPreviewTrigger.focus();
  };

  const setupPdfPreviewLink=(link)=>{
    const href=link.getAttribute('href');
    if(!href||!href.startsWith('/')||href.startsWith('/downloads/'))return;
    link.addEventListener('click',(event)=>{
      if(event.defaultPrevented||event.button!==0||event.metaKey||event.ctrlKey||event.shiftKey||event.altKey)return;
      event.preventDefault();
      pdfPreviewTrigger=link;
      pdfPreviewTitle.textContent=getPdfTitle(link);
      pdfPreviewFrame.src=`${href}#view=FitH`;
      pdfPreviewOpen.href=href;
      pdfPreviewDownload.href=href;
      pdfPreview.hidden=false;
      document.body.classList.add('pdf-preview-open');
      setPageInert(true);
      pdfPreviewClose.focus();
    });
  };
  document.querySelectorAll('a[href$=".pdf"]').forEach(setupPdfPreviewLink);

  pdfPreviewClose.addEventListener('click',closePdfPreview);
  pdfPreviewDialog.addEventListener('keydown',event=>{trapFocus(event,pdfPreviewDialog)});
  pdfPreview.addEventListener('click',(event)=>{if(event.target===pdfPreview)closePdfPreview();});
  document.addEventListener('keydown',(event)=>{if(event.key==='Escape'&&!pdfPreview.hidden)closePdfPreview();});
</script>
{% endblock %}
