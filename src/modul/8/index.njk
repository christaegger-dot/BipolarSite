      <div class="pdf-preview-note">Die Vorschau bleibt auf dieser Seite. Für Reader oder Druckansicht können Sie das PDF direkt öffnen.</div>
      <div class="pdf-preview-frame-wrap">
        <iframe class="pdf-preview-frame" id="pdf-preview-frame" title="PDF-Vorschau" loading="lazy"></iframe>
      </div>
    </div>
  </div>
</div>
{% endblock %}
