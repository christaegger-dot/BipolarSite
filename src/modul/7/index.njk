  <!-- HANDOUTS -->
  <div class="handouts reveal">
    <div class="handouts-title">Passende Handouts</div>
    <div class="handouts-grid">
      <a href="/handouts/c6_selbstfuersorge.pdf" target="_blank" rel="noopener" class="handout-card"><div class="handout-icon green">PDF</div><div><div class="handout-card-title">Selbstfürsorge-Plan</div><div class="handout-card-sub">Körper, Seele, Beziehung</div></div></a>
