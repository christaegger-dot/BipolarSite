      <a href="/handouts/trialog.pdf" target="_blank" rel="noopener" class="handout-card"><div class="handout-icon green">PDF</div><div><div class="handout-card-title">Trialog</div><div class="handout-card-sub">Gemeinsam statt übereinander</div></div></a>
      <a href="/handouts/transformationsreise.pdf" target="_blank" rel="noopener" class="handout-card"><div class="handout-icon green">PDF</div><div><div class="handout-card-title">Veränderung über Zeit</div><div class="handout-card-sub">Wachstum ohne Pflicht</div></div></a>
    </div>
  </div>

  <!-- NEXT -->
  <div class="next-module reveal">
    <a href="/modul/8/" class="next-module-card">
      <div>
        <div class="next-module-label">Nächster Schritt</div>
