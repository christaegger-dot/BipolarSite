        <text x="250" y="260" text-anchor="middle" font-family="DM Serif Display, serif" font-size="15" font-weight="600" fill="#1c2b3a">Anspannung</text>
        <text x="250" y="282" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="10.5" fill="#94a3b8">↻ selbstverstärkend</text>

