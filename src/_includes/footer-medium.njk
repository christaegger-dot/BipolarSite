<footer class="site-footer"><div class="footer-inner footer-inner--editorial">
  <div class="footer-meta">
    <p class="footer-org">{{ site.org }}</p>
    <p>{{ site.department }}</p>
    <p class="footer-contact">
      <a href="tel:{{ site.phone | replace(' ', '') }}">{{ site.phone }}</a><br>
      <a href="mailto:{{ site.email }}">{{ site.email }}</a>
    </p>
    <p class="footer-address">{{ site.address }}</p>
    {% if footerAttribution %}<p class="footer-attribution">{{ footerAttribution }}</p>{% endif %}
  </div>
  <div class="footer-note">
    <p class="footer-invitation">Sie dürfen sich Hilfe holen — auch für sich selbst.</p>
    <p class="footer-disclaimer">Diese Inhalte ersetzen keine professionelle Beratung. In akuten Lagen hat der Notfallweg Vorrang.</p>
    <div class="footer-links">
      <a href="/impressum/#impressum">Impressum</a>
      <a href="/impressum/#datenschutz">Datenschutz</a>
      <a href="/impressum/#barrierefreiheit">Barrierefreiheit</a>
      <a href="/notfall/" class="footer-link-alert">Notfall &amp; Krisenhilfe</a>
    </div>
  </div>
</div></footer>
