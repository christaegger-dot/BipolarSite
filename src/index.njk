{% block scripts %}
<script>document.documentElement.classList.remove('no-js')

  // ── Scroll reveal (IntersectionObserver) ──
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
  }

  // ══════════ Quick Triage ══════════
  (function() {
    var result = document.getElementById('triageResult');
    if (!result) return;

    var responses = {
      'q1-yes': { html: '<a href="/notfall/">Zum Notfallweg &rarr;</a>', cls: 'triage-result--urgent' },
      'q1b-yes': { html: '<a href="/modul/1/#neu">Erste Orientierung: Diagnose neu &rarr;</a>', cls: 'triage-result--safe' },
      'q2-yes': { html: '<a href="/modul/4/">Modul 4: Wenn die Kraft nachlässt &rarr;</a>', cls: '' },
      'q3-yes': { html: '<a href="/modul/1/">Modul 1: Die bipolare Störung verstehen &rarr;</a>', cls: '' },
      'q4-beziehung': { html: '<a href="/modul/3/">Modul 3: Wie Beziehungen unter Druck geraten &rarr;</a>', cls: 'triage-result--safe' },
      'q4-handeln':   { html: '<a href="/modul/6/">Modul 6: Was Sie konkret tun können &rarr;</a>', cls: 'triage-result--safe' },
      'q4-selbst':    { html: '<a href="/modul/2/">Modul 2: Was das mit Ihnen macht &rarr;</a>', cls: 'triage-result--safe' }
    };

    document.getElementById('quickTriage').addEventListener('click', function(e) {
      var btn = e.target.closest('[data-triage]');
      if (!btn) return;
      var action = btn.dataset.triage;

      if (action === 'q1-no') {
        document.getElementById('triageQ1').hidden = true;
        document.getElementById('triageQ1b').hidden = false;
      } else if (action === 'q1b-no') {
        document.getElementById('triageQ1b').hidden = true;
        document.getElementById('triageQ2').hidden = false;
      } else if (action === 'q2-no') {
        document.getElementById('triageQ2').hidden = true;
        document.getElementById('triageQ3').hidden = false;
      } else if (action === 'q3-no') {
        document.getElementById('triageQ3').hidden = true;
        document.getElementById('triageQ4').hidden = false;
      } else if (responses[action]) {
        var r = responses[action];
        result.className = 'triage-result' + (r.cls ? ' ' + r.cls : '');
        result.innerHTML = r.html + '<button type="button" class="triage-restart" data-triage="restart">Nochmal beantworten</button>';
        result.hidden = false;
        // hide all questions
        document.querySelectorAll('.triage-question').forEach(function(q) { q.hidden = true; });
      } else if (action === 'restart') {
        result.hidden = true;
        result.className = 'triage-result';
        document.getElementById('triageQ1').hidden = false;
      }
    });
  })();

  // ══════════ Module Progress ══════════
  (function() {
    try {
      if (localStorage.getItem('puk_storage_consent') !== 'true') return;
      var visited = JSON.parse(localStorage.getItem('puk_visited_modules') || '[]');
      var visitedNums = visited.map(function(p) { var m = p.match(/\d+/); return m ? parseInt(m[0]) : 0; }).filter(Boolean);
      if (!visitedNums.length) return;

      // Progress bar
      var bar = document.getElementById('homeProgressBar');
      var fill = document.getElementById('homeProgressFill');
      var count = document.getElementById('homeProgressCount');
      if (bar && fill && count) {
        bar.hidden = false;
        var pct = Math.round((visitedNums.length / 8) * 100);
        count.textContent = visitedNums.length + ' von 8 Modulen';
        fill.style.width = pct + '%';
      }

      // Mark visited cards
      document.querySelectorAll('a.module-card[href]').forEach(function(card) {
        var href = card.getAttribute('href');
        var m = href.match(/\/modul\/(\d+)/);
        if (m && visitedNums.indexOf(parseInt(m[1])) !== -1) {
          card.classList.add('visited');
          var arrow = card.querySelector('.module-arrow');
          if (arrow && arrow.textContent.trim() === '\u2192') arrow.textContent = '\u2713';
        }
      });
    } catch(e) { console.warn('Progress:', e.message); }
  })();

</script>
