{% block scripts %}
<script>document.documentElement.classList.remove('no-js')

  // ── Scroll reveal (IntersectionObserver) ──
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
  }

  // ── Module progress tracking (localStorage) ──
  const TOTAL_MODULES = 8;
  const STORAGE_KEY = 'puk_visited_modules';

  function getVisited() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { return []; }
  }

  function saveVisited(list) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(list)); } catch {}
  }

  function getModulePath(href) {
    const m = href && href.match(/^\/modul\/(\d+)\/?$/);
    return m ? '/modul/' + m[1] + '/' : null;
  }

  const START_HELPER = {
    akut: {
      title: 'Beginnen Sie mit der Notfallseite',
      text: 'Wenn Gefahr, Kontrollverlust oder starke Unsicherheit im Raum stehen, ist zuerst die Triage wichtiger als alles andere.',
      href: '/notfall/',
      cta: 'Notfallweg öffnen →'
    },
    verstehen: {
      title: 'Beginnen Sie mit Modul 1',
      text: 'Dort bekommen Sie die Grundlagen, mit denen spätere Entscheidungen und Belastungen oft besser einordenbar werden.',
      href: '/modul/1/',
      cta: 'Modul 1 öffnen →'
    },
    erschoepft: {
      title: 'Beginnen Sie mit Modul 4',
      text: 'Wenn Ihre eigene Belastung gerade lauter ist als alle anderen Fragen, ist das meist der entlastendste Einstieg.',
      href: '/modul/4/',
      cta: 'Modul 4 öffnen →'
    },
    hilfe: {
      title: 'Beginnen Sie mit Modul 8',
      text: 'Dort finden Sie Kontakte, Materialien und rechtliche Orientierung. Wenn Sie danach vor allem Gespräche, Grenzen oder einen Krisenplan brauchen, wechseln Sie weiter zu Modul 6.',
      href: '/modul/8/',
      cta: 'Modul 8 öffnen →'
    }
  };

  const startHelperButtons = document.querySelectorAll('[data-start-helper]');
  const startHelperResult = document.getElementById('startHelperResult');
  const startHelperTitle = document.getElementById('startHelperTitle');
  const startHelperText = document.getElementById('startHelperText');
  const startHelperLink = document.getElementById('startHelperLink');

  function updateStartHelper(key) {
    const entry = START_HELPER[key];
    if (!entry || !startHelperResult) return;
    startHelperButtons.forEach(btn => {
      const isActive = btn.dataset.startHelper === key;
      btn.classList.toggle('is-active', isActive);
      btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    });
    startHelperTitle.textContent = entry.title;
    startHelperText.textContent = entry.text;
    startHelperLink.href = entry.href;
    startHelperLink.textContent = entry.cta;
    startHelperResult.hidden = false;
  }

  function updateProgressUI() {
    const visited = getVisited();
    const count = Math.min(visited.length, TOTAL_MODULES);
    const pct = (count / TOTAL_MODULES) * 100;

    const fill = document.getElementById('progressFill');
    const counter = document.getElementById('progressCount');
    const section = document.getElementById('progressSection');
    if (fill) fill.style.width = pct + '%';
    if (counter) counter.textContent = count + ' / ' + TOTAL_MODULES + ' Module';
    if (section) section.classList.toggle('is-empty', count === 0);

    // Mark visited module cards
    document.querySelectorAll('a.module-card[href]').forEach(card => {
      const path = getModulePath(card.getAttribute('href'));
      if (path && visited.includes(path)) {
        card.classList.add('visited');
        const arrow = card.querySelector('.module-arrow');
        if (arrow && arrow.textContent.trim() === '→') arrow.textContent = '✓';
      }
    });
  }

  // Track clicks on module cards
  document.querySelectorAll('a.module-card[href]').forEach(card => {
    const path = getModulePath(card.getAttribute('href'));
    if (path) {
      card.addEventListener('click', () => {
        const visited = getVisited();
        if (!visited.includes(path)) {
          visited.push(path);
          saveVisited(visited);
        }
      });
    }
  });

  startHelperButtons.forEach(button => {
    button.addEventListener('click', () => updateStartHelper(button.dataset.startHelper));
  });

  // Initialise progress on load
  updateProgressUI();

  // ══════════ Quick Triage ══════════
  (function() {
    var result = document.getElementById('triageResult');
    if (!result) return;

    var responses = {
      'q1-yes': { html: '<a href="/notfall/">Zum Notfallweg &rarr;</a>', cls: '' },
      'q2-yes': { html: '<a href="/modul/4/">Modul 4: Wenn die Kraft nachlässt &rarr;</a>', cls: '' },
      'q3-yes': { html: '<a href="/modul/1/">Modul 1: Die bipolare Störung verstehen &rarr;</a>', cls: '' },
      'q3-no':  { html: '<p>Nutzen Sie den Starthelfer unten oder stöbern Sie in den <a href="/werkzeuge/" style="color:var(--teal);font-weight:600">Werkzeugen</a>.</p>', cls: 'triage-result--safe' }
    };

    document.getElementById('quickTriage').addEventListener('click', function(e) {
      var btn = e.target.closest('[data-triage]');
      if (!btn) return;
      var action = btn.dataset.triage;

      if (action === 'q1-no') {
        document.getElementById('triageQ1').hidden = true;
        document.getElementById('triageQ2').hidden = false;
      } else if (action === 'q2-no') {
        document.getElementById('triageQ2').hidden = true;
        document.getElementById('triageQ3').hidden = false;
      } else if (responses[action]) {
        var r = responses[action];
        result.className = 'triage-result' + (r.cls ? ' ' + r.cls : '');
        result.innerHTML = r.html;
        result.hidden = false;
        // hide all questions
        document.querySelectorAll('.triage-question').forEach(function(q) { q.hidden = true; });
      }
    });
  })();

</script>
{% endblock %}
