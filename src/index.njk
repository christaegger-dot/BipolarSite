  .quick-triage{background:linear-gradient(135deg,var(--rose-soft),#fff8f6);border:2px solid rgba(154,52,18,0.18);border-radius:var(--radius-md);padding:28px 32px;margin-bottom:24px;box-shadow:0 4px 24px rgba(154,52,18,0.08)}
