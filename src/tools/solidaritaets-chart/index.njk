---
layout: "base"
title: "Belastungsverlauf über Episoden | PUK Zürich"
description: "Belastungsverlauf über Episoden: Wie sich Belastungsreserve und Stimmung über mehrere Episoden entwickeln. Konzeptionelles Modell für Angehörige. PUK Zürich."
permalink: "/tools/solidaritaets-chart/"
toolBackHref: "/modul/4/"
toolBackLabel: "Zurück zu Modul 4"
useSharedCSS: true
useNavJS: false
useToolCSS: true
---
{% block headCSS %}
<style>
body{font-family:'DM Sans',sans-serif;color:var(--navy);background:var(--bg);min-height:100vh;display:flex;flex-direction:column;align-items:center;-webkit-font-smoothing:antialiased}
.tool-nav{width:100%;background:rgba(254,252,248,0.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--border-warm);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:var(--z-tool-nav)}
.wrap{width:100%;max-width:680px;padding:32px 20px 48px;flex:1}
.hdr{text-align:center;margin-bottom:24px;background:linear-gradient(180deg,rgba(255,255,255,0.94),rgba(247,250,251,0.88));border:1px solid var(--border-warm-md);border-radius:26px;padding:26px 24px 24px;box-shadow:var(--shadow-elevated);position:relative;overflow:hidden}
.legend{display:flex;gap:16px;justify-content:center;margin-bottom:16px;flex-wrap:wrap}
.legend-item{display:flex;align-items:center;gap:6px;font-size:0.72rem;color:var(--slate);cursor:pointer;padding:4px 8px;border-radius:6px;transition:background 0.2s}
.legend-item:hover{background:var(--border-warm)}
.legend-line{width:20px;height:3px;border-radius:2px}
.chart-wrap{width:100%;background:linear-gradient(180deg,var(--card) 0%,#fbfcfd 100%);border-radius:22px;border:1px solid var(--border-warm);box-shadow:var(--shadow-card);padding:20px;margin-bottom:16px;overflow-x:auto}
.chart-wrap svg{width:100%;height:auto;display:block}
.chart-wrap [role="button"]:focus{filter:drop-shadow(0 0 0.35rem rgba(116,138,90,0.45))}
.episodes{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;justify-content:center}
.ep-btn{padding:8px 16px;border-radius:10px;border:1px solid var(--border-warm-md);background:var(--card);font-size:0.78rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background-color 0.2s ease,color 0.2s ease,border-color 0.2s ease;-webkit-appearance:none}
.ep-btn.active{color:var(--card)}
.detail{background:linear-gradient(180deg,var(--card) 0%,#fbfcfd 100%);border-radius:22px;border:1px solid var(--border-warm);box-shadow:var(--shadow-card);padding:24px;margin-bottom:16px;display:none}
.detail.vis{display:block}
.detail h2{font-family:'DM Serif Display',Georgia,serif;font-size:1rem;font-weight:700;color:var(--navy);margin:0 0 12px}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.detail-col{padding:12px;border-radius:10px;font-size:0.82rem;line-height:1.5}
.detail-col h4{font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px}
.toggle-wrap{text-align:center;margin-bottom:16px}
.toggle-btn{padding:10px 20px;border-radius:10px;border:2px solid var(--green-phase);background:var(--card);color:var(--green-phase);font-size:0.82rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background-color 0.2s ease,color 0.2s ease,border-color 0.2s ease}
.toggle-btn.on{background:var(--green-phase);color:var(--card)}
.disc{text-align:center;font-size:0.72rem;color:var(--slate);background:var(--bg);border-radius:10px;padding:12px 16px;margin-bottom:16px;line-height:1.5}
.mobile-chart-note{display:none;background:var(--bg);border:1px solid var(--border-warm-md);border-radius:14px;padding:12px 14px;margin-bottom:14px;font-size:0.76rem;line-height:1.55;color:var(--slate);text-align:center}
.tf{text-align:center;font-size:0.68rem;color:var(--teal-light);margin-top:20px;line-height:1.5}
@media(max-width:600px){.chart-wrap{display:none}.mobile-chart-note{display:block}.detail-grid{grid-template-columns:1fr}}
</style>
{% endblock %}
{% block nav %}
{% include "nav-tool.njk" %}
{% endblock %}
{% block content %}
<main class="wrap" id="main-content">
  <div class="hdr">
<div class="tool-breadcrumb"><a href="/">Startseite</a><span class="sep" aria-hidden="true">›</span><a href="/werkzeuge/">Werkzeuge</a><span class="sep" aria-hidden="true">›</span><span>Belastungsverlauf</span></div>
<div class="tool-glyph" aria-hidden="true"><svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 28C10 22 14 12 18 12C22 12 23 30 28 30C31 30 33 22 34 18" stroke="#A8E4E8" stroke-width="3.4" stroke-linecap="round"/><path d="M6 20C10 19 13 22 18 22C23 22 25 14 30 14C32 14 34 15 36 17" stroke="#5B7FA5" stroke-width="3" stroke-linecap="round"/></svg></div><div class="badge">Modul 4 — Interaktiv</div><h1>Belastungsverlauf über Episoden</h1><p>Wie sich Belastungsreserve und Stimmung über wiederholte Episoden verändern. Klicken Sie auf eine Episode.</p></div>
  <div class="legend">
    <div class="legend-item"><div class="legend-line" style="background:var(--amber-phase)"></div>Belastungsreserve</div>
    <div class="legend-item"><div class="legend-line" style="background:var(--blue-phase)"></div>Stimmung der erkrankten Person</div>
    <div class="legend-item" id="legSupport" style="display:none"><div class="legend-line" style="background:var(--green-phase);border-style:dashed"></div>Mit Unterstützung abgefedert</div>
  </div>
  <div class="mobile-chart-note">Auf kleinen Screens ist das Diagramm ausgeblendet, damit die Episode-Auswahl und die Erklärung ruhiger bleiben. Wählen Sie unten direkt eine Episode.</div>
  <div class="chart-wrap">
    <svg viewBox="0 0 600 280" role="group" aria-label="Konzeptionelles Modell: Belastungsreserve und Stimmung über mehrere Episoden">
      <!-- Grid -->
      <line x1="60" y1="20" x2="60" y2="240" stroke="#e6f4f2" stroke-width="1"/>
      <line x1="60" y1="130" x2="580" y2="130" stroke="#e6f4f2" stroke-width="1" stroke-dasharray="4 4"/>
      <line x1="60" y1="240" x2="580" y2="240" stroke="#e6f4f2" stroke-width="1"/>
      <text x="55" y="26" text-anchor="end" font-size="9" fill="#8DD4D9">Hoch</text>
      <text x="55" y="134" text-anchor="end" font-size="9" fill="#8DD4D9">Mittel</text>
      <text x="55" y="244" text-anchor="end" font-size="9" fill="#8DD4D9">Niedrig</text>
      <!-- Episode bands -->
      <rect id="ep0" x="80" y="20" width="120" height="220" fill="rgba(196,147,59,0.06)" rx="4" style="cursor:pointer" aria-hidden="true" focusable="false"/>
      <rect id="ep1" x="240" y="20" width="140" height="220" fill="rgba(199,84,80,0.06)" rx="4" style="cursor:pointer" aria-hidden="true" focusable="false"/>
      <rect id="ep2" x="420" y="20" width="160" height="220" fill="rgba(91,127,165,0.06)" rx="4" style="cursor:pointer" aria-hidden="true" focusable="false"/>
      <text x="140" y="256" text-anchor="middle" font-size="9" fill="#8DD4D9">Hypomanie</text>
      <text x="310" y="256" text-anchor="middle" font-size="9" fill="#8DD4D9">Schwere Manie</text>
      <text x="500" y="256" text-anchor="middle" font-size="9" fill="#8DD4D9">Lange Depression</text>
      <!-- Belastbarkeit curve (amber) -->
      <path d="M80,60 Q140,50 160,80 Q200,120 240,100 Q280,70 310,150 Q340,210 380,190 Q420,170 460,180 Q500,195 540,200 Q560,205 580,210" fill="none" stroke="var(--amber-phase)" stroke-width="3" stroke-linecap="round" id="curveBel"/>
      <!-- Stimmung curve (blue) -->
      <path d="M80,120 Q120,60 160,40 Q200,80 230,130 Q260,30 310,20 Q340,60 380,130 Q420,170 460,200 Q500,220 540,210 Q560,200 580,190" fill="none" stroke="var(--blue-phase)" stroke-width="3" stroke-linecap="round" id="curveSt"/>
      <!-- Support curve (green, hidden) -->
      <path d="M80,60 Q140,55 160,70 Q200,90 240,80 Q280,70 310,110 Q340,140 380,130 Q420,120 460,125 Q500,130 540,128 Q560,126 580,130" fill="none" stroke="var(--green-phase)" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="8 5" opacity="0" id="curveSup"/>
    </svg>
  </div>
  <div class="episodes">
    <button class="ep-btn" type="button" style="--c:var(--amber-phase)" data-ep="0" aria-pressed="false">Hypomanie</button>
    <button class="ep-btn" type="button" style="--c:var(--rose)" data-ep="1" aria-pressed="false">Schwere Manie</button>
    <button class="ep-btn" type="button" style="--c:var(--blue-phase)" data-ep="2" aria-pressed="false">Lange Depression</button>
  </div>
  <div class="detail" id="detail" aria-live="polite"></div>
  <div class="toggle-wrap"><button class="toggle-btn" id="toggleBtn" type="button" aria-pressed="false">Mit Entlastung vergleichen</button></div>
  <div class="disc"><strong>Konzeptionelles Modell</strong> — es soll sichtbar machen, warum Belastung sich über Episoden oft kumuliert und Erholung unvollständig bleiben kann. Individuelle Verläufe können erheblich abweichen. Quellen: Perlick et al. (2007); Reinares et al. (2016); Miklowitz (2010).</div>
  <noscript>
    <div style="padding:20px 24px;background:var(--surface-warm);border-radius:12px;margin:20px 0;font-family:'DM Sans',sans-serif">
      <p style="font-weight:600;margin:0 0 8px">Die interaktive Visualisierung benötigt JavaScript.</p>
      <p style="margin:0">Den Belastungsverlauf finden Sie auch in <a href="/modul/4/" style="color:var(--teal);font-weight:600">Modul 4</a>.</p>
    </div>
  </noscript>
</main>
{% endblock %}
{% block footer %}
{% include "footer-medium.njk" %}
{% endblock %}
{% block scripts %}
<script>
const eps=[
  {name:"Hypomanie",col:"var(--amber-phase)",bg:"rgba(196,147,59,0.1)",impact:"Leicht–Mittel",bel:"Die Belastungsreserve sinkt oft zunächst nur leicht. Gerade das macht Hypomanie für Angehörige schwer lesbar: Viel wirkt noch produktiv oder charmant, gleichzeitig werden Schlaf, Reizbarkeit und Unsicherheit grösser.",stim:"Die Stimmung steigt an — mehr Energie, weniger Schlaf, grössere Ideen. Für Angehörige bleibt oft unklar, ob es noch eine gute Phase ist oder schon der Beginn einer Episode."},
  {name:"Schwere Manie",col:"var(--rose)",bg:"rgba(199,84,80,0.1)",impact:"Hoch",bel:"Die Belastungsreserve bricht deutlich ein. Sicherheit, Geld, Konflikte, Kontrollverlust und Schlafentzug kommen oft gleichzeitig. Nach einer schweren Manie fühlt sich Erholung selten wie ein echter Neustart an.",stim:"Der Ausschlag nach oben wird extrem: Grössenideen, Impulsivität, Gereiztheit, möglicherweise Psychose. Professionelle Intervention oder Hospitalisation ist häufig nötig."},
  {name:"Lange Depression",col:"var(--blue-phase)",bg:"rgba(91,127,165,0.1)",impact:"Mittel–Hoch",bel:"Die Belastungsreserve sinkt langsamer, aber stetig. Gerade diese schleichende Form wird oft unterschätzt: wenig sichtbare Dramatik, aber hohe Langzeitlast, Monotonie und innere Ausdünnung.",stim:"Die Stimmung bleibt über Wochen oder Monate tief. Rückzug, Hoffnungslosigkeit, verlangsamter Alltag und Suizidgedanken können Angehörige auf andere Weise zermürben als eine Manie."}
];
let activeEp=null,showSup=false;
// Cache DOM references to avoid repeated queries on every render
const epBtns=document.querySelectorAll('.ep-btn');
const epRects=[0,1,2].map(i=>document.getElementById('ep'+i));
const elDetail=document.getElementById('detail');
function selEp(i){activeEp=activeEp===i?null:i;rn()}
function toggleSupport(){showSup=!showSup;document.getElementById('curveSup').setAttribute('opacity',showSup?'1':'0');document.getElementById('toggleBtn').classList.toggle('on',showSup);document.getElementById('toggleBtn').setAttribute('aria-pressed',showSup?'true':'false');document.getElementById('toggleBtn').textContent=showSup?'Entlastungsvergleich ausblenden':'Mit Entlastung vergleichen';document.getElementById('legSupport').style.display=showSup?'flex':'none'}
function rn(){
  // Episode buttons
  epBtns.forEach((btn,i)=>{
    const a=activeEp===i;
    btn.classList.toggle('active',a);
    btn.style.background=a?eps[i].col:'#fff';
    btn.style.color=a?'#fff':'#475569';
    btn.style.borderColor=a?eps[i].col:'rgba(28,43,58,0.08)';
    btn.setAttribute('aria-pressed',a?'true':'false');
  });
  // Episode bands
  epRects.forEach((rect,i)=>{
    rect.setAttribute('fill',activeEp===i?eps[i].bg:'rgba(0,0,0,0.02)');
  });
  // Detail
  if(activeEp!==null){
    const e=eps[activeEp];
    elDetail.className='detail vis';
    elDetail.innerHTML=`<h2>${e.name} <span style="font-size:0.72rem;font-weight:600;color:${e.col};background:${e.bg};padding:2px 8px;border-radius:6px;margin-left:8px">Belastung: ${e.impact}</span></h2>
    <div class="detail-grid"><div class="detail-col" style="background:var(--amber-phase-light)"><h4 style="color:var(--amber-phase)">Belastungsreserve</h4><p style="color:var(--slate)">${e.bel}</p></div><div class="detail-col" style="background:var(--blue-phase-light)"><h4 style="color:var(--blue-phase)">Stimmung</h4><p style="color:var(--slate)">${e.stim}</p></div></div>`;
  }else{elDetail.className='detail'}
}
[0,1,2].forEach(i=>{const el=document.getElementById('ep'+i);el.addEventListener('click',()=>selEp(i));});
document.querySelector('.episodes').addEventListener('click',e=>{const btn=e.target.closest('.ep-btn[data-ep]');if(btn)selEp(Number(btn.dataset.ep))});
document.getElementById('toggleBtn').addEventListener('click',toggleSupport);
</script>
{% endblock %}
