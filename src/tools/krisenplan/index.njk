---
layout: "base"
title: "Krisenplan-Werkzeug | PUK Zürich"
description: "Interaktives Krisenplan-Werkzeug: Frühwarnzeichen, Massnahmen, Kontakte — gemeinsam in stabiler Phase ausfüllen. PUK Zürich."
permalink: "/tools/krisenplan/"
toolBackHref: "/modul/6/"
toolBackLabel: "Zurück zu Modul 6"
useSharedCSS: true
useNavJS: false
useToolCSS: true
bodyClass: "krisenplan-page"
breadcrumbs:
  - name: "Werkzeuge"
    url: "/werkzeuge/"
  - name: "Krisenplan"
    url: "/tools/krisenplan/"
---
{% block headCSS %}<!-- Krisenplan styles migrated to tools.css (P2.4) -->{% endblock %}
{% block nav %}
<nav class="tool-nav">
  <a href="{{ toolBackHref }}" class="tool-back"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>{{ toolBackLabel }}</a>
  <div class="tool-actions">
    <button type="button" id="btnSave" class="btn-save">Speichern</button>
    <button type="button" id="btnPrint" class="btn-print">Drucken</button>
    <button type="button" id="btnReset" class="btn-reset">Zurücksetzen</button>
  </div>
</nav>
{% endblock %}
{% block content %}
<div id="savedMsg" class="saved-msg" role="status" aria-live="polite">Gespeichert ✓</div>
<dialog id="confirm" class="confirm" aria-labelledby="confirm-title">
  <div class="confirm-box">
    <h2 id="confirm-title">Krisenplan zurücksetzen?</h2>
    <p>Alle eingetragenen Daten werden unwiderruflich gelöscht. Diese Aktion kann nicht rückgängig gemacht werden.</p>
    <div class="confirm-btns">
      <button type="button" id="btnConfirmCancel" class="confirm-cancel">Abbrechen</button>
      <button type="button" id="btnConfirmDelete" class="confirm-delete">Endgültig löschen</button>
    </div>
  </div>
</dialog>
<main id="main-content" class="wrap">
  <div class="print-hdr"><div class="print-title">Unser Krisenplan</div><p>Erstellt am: <span id="printDate"></span> · Psychiatrische Universitätsklinik Zürich</p></div>
  <div class="hdr">
<div class="tool-breadcrumb"><a href="/">Startseite</a><span class="sep" aria-hidden="true">›</span><a href="/werkzeuge/">Werkzeuge</a><span class="sep" aria-hidden="true">›</span><span>Krisenplan-Werkzeug</span></div>
<div class="tool-glyph" aria-hidden="true"><svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="10" y="7" width="20" height="26" rx="4" fill="var(--teal-light)"/><path d="M15 14H25" stroke="var(--teal-solid)" stroke-width="2.4" stroke-linecap="round"/><path d="M15 20H25" stroke="var(--teal-solid)" stroke-width="2.4" stroke-linecap="round"/><path d="M15 26H21" stroke="var(--teal-solid)" stroke-width="2.4" stroke-linecap="round"/></svg></div><h1>Krisenplan-Werkzeug</h1><p>Füllen Sie diesen Plan gemeinsam in einer stabilen Phase aus. Er soll in belastenden Situationen Entscheidungslast reduzieren. Alles bleibt auf Ihrem Gerät — nichts wird gesendet.</p></div>
  <div class="prog-wrap"><div class="prog-bar"><div class="prog-fill" id="progFill"></div></div><div class="prog-label" id="progLabel"></div></div>
  <form id="form" autocomplete="off">
    <div class="section s1"><h2><span class="section-step" aria-hidden="true">1</span> Frühwarnzeichen</h2><p class="sdesc">Was sind die ersten Anzeichen, dass eine Episode beginnen könnte?</p>
      <div class="field"><label for="warn_manie">Manie-Warnzeichen</label><textarea id="warn_manie" name="warn_manie" placeholder="z.B. weniger Schlafbedürfnis, schnelleres Reden, grosse Pläne, Reizbarkeit..."></textarea></div>
      <div class="field"><label for="warn_dep">Depressions-Warnzeichen</label><textarea id="warn_dep" name="warn_dep" placeholder="z.B. Rückzug, Appetitlosigkeit, frühmorgendliches Erwachen, Antriebslosigkeit..."></textarea></div>
    </div>
    <div class="section s2"><h2><span class="section-step" aria-hidden="true">2</span> Massnahmen Stufe 1 — Frühphase</h2><p class="sdesc">Was tun wir bei den ersten Anzeichen?</p>
      <div class="field"><label for="mass1">Vereinbarte Sofort-Massnahmen</label><textarea id="mass1" name="mass1" placeholder="z.B. Schlafrhythmus sicherstellen, Medikation prüfen, Psychiater kontaktieren..."></textarea></div>
      <div class="field"><label for="inform1">Wer muss informiert werden?</label><textarea id="inform1" name="inform1" placeholder="z.B. Psychiater*in, Hausarzt, enge Vertrauensperson..."></textarea></div>
    </div>
    <div class="section s3"><h2><span class="section-step" aria-hidden="true">3</span> Massnahmen Stufe 2 — Akutphase</h2><p class="sdesc">Was tun wir, wenn die Situation eskaliert?</p>
      <div class="field"><label for="mass2">Akut-Massnahmen</label><textarea id="mass2" name="mass2" placeholder="z.B. Psychiatrischen Notfalldienst rufen, Klinik aufsuchen, Finanzen sperren lassen..."></textarea></div>
      <div class="field"><label for="grenze">Grenze für Hospitalisation</label><textarea id="grenze" name="grenze" placeholder="z.B. Wenn Suizidgedanken geäussert werden, wenn Fremdgefährdung besteht, wenn 3 Tage kein Schlaf..."></textarea></div>
    </div>
    <div class="section s4"><h2><span class="section-step" aria-hidden="true">4</span> Kontaktpersonen</h2><p class="sdesc">Alle wichtigen Nummern — griffbereit.</p>
      <div class="field"><label for="kontakt_psych">Psychiater*in / Therapeut*in</label><input id="kontakt_psych" type="tel" name="kontakt_psych" placeholder="Name und Telefonnummer" aria-describedby="kontakt_psych_hint"><small id="kontakt_psych_hint" class="sdesc">z.B. Dr. Müller, +41 44 123 45 67</small></div>
      <div class="field"><label for="kontakt_ha">Hausarzt / Hausärztin</label><input id="kontakt_ha" type="tel" name="kontakt_ha" placeholder="Name und Telefonnummer" aria-describedby="kontakt_ha_hint"><small id="kontakt_ha_hint" class="sdesc">z.B. Dr. Meier, +41 44 234 56 78</small></div>
      <div class="field"><label for="kontakt_vp">Vertrauensperson</label><input id="kontakt_vp" type="tel" name="kontakt_vp" placeholder="Name und Telefonnummer" aria-describedby="kontakt_vp_hint"><small id="kontakt_vp_hint" class="sdesc">z.B. Maria, +41 79 345 67 89</small></div>
      <div class="field"><label for="kontakt_klinik">Bevorzugte Klinik</label><input id="kontakt_klinik" type="text" name="kontakt_klinik" placeholder="Name, Adresse, Notfallnummer" aria-describedby="kontakt_klinik_hint"><small id="kontakt_klinik_hint" class="sdesc">z.B. PUK Zürich, Lenggstrasse 31, 058 384 21 11</small></div>
    </div>
    <div class="section s5"><h2><span class="section-step" aria-hidden="true">5</span> Klinikwunsch</h2><p class="sdesc">Wünsche für eine mögliche stationäre Behandlung.</p>
      <div class="field"><label for="klinik">Bevorzugte Klinik und besondere Wünsche</label><textarea id="klinik" name="klinik" placeholder="z.B. Einzelzimmer, bestimmte Station, Besuchsregelung, Medikamentenwünsche..."></textarea></div>
    </div>
    <div class="section s6"><h2><span class="section-step" aria-hidden="true">6</span> Zusätzliches</h2><p class="sdesc">Alles, was sonst noch wichtig ist.</p>
      <div class="field"><label for="schweige">Schweigepflichtentbindung vorhanden?</label><input id="schweige" type="text" name="schweige" placeholder="Ja / Nein / In Arbeit — wo hinterlegt?"></div>
      <div class="field"><label for="finanzen">Finanzielle Vorkehrungen</label><textarea id="finanzen" name="finanzen" placeholder="z.B. Kreditkartenlimit, Kontovollmacht, Bankgespräch geführt?"></textarea></div>
      <div class="field"><label for="sonstiges">Sonstiges</label><textarea id="sonstiges" name="sonstiges" placeholder="Alles weitere, das in einer Krise wichtig sein könnte..."></textarea></div>
    </div>
  </form>
  <noscript>
    <div class="noscript-box">
      <p>Dieses Werkzeug benötigt JavaScript.</p>
      <p>Sie können alternativ die <a href="/downloads/krisenplan-vorlage-bipolare-stoerung-puk-zuerich.pdf">Krisenplan-Vorlage als PDF</a> herunterladen oder <a href="/modul/6/">Modul 6</a> lesen.</p>
    </div>
  </noscript>
</main>
{% endblock %}
{% block footer %}
{% include "footer-medium.njk" %}
{% endblock %}
{% block scripts %}
<script>
const KEY='krisenplan-v1';
const fields=document.querySelectorAll('textarea,input');
const totalFields=fields.length;
// Cache DOM references used on every progress update
const progFill=document.getElementById('progFill');
const progLabel=document.getElementById('progLabel');
const confirmDialog=document.getElementById('confirm');
// Single shared debounce timer — avoids storing state on DOM nodes
let saveTimer;
let confirmTrigger=null;

// Load
function load(){
  try{
    const d=JSON.parse(localStorage.getItem(KEY));
    if(d){fields.forEach(f=>{if(d[f.name])f.value=d[f.name]})}
  }catch(e){console.warn('Storage unavailable:',e.message)}
  updateProg();
}

// Save
const savedMsg=document.getElementById('savedMsg');
function save(){
  const d={};
  fields.forEach(f=>{if(f.value.trim())d[f.name]=f.value.trim()});
  try{
    localStorage.setItem(KEY,JSON.stringify(d));
    savedMsg.textContent='Gespeichert \u2713';
    savedMsg.classList.add('vis');
  }catch(e){
    savedMsg.textContent='Speichern nicht möglich — privater Modus?';
    savedMsg.style.background='var(--alert)';
    savedMsg.classList.add('vis');
  }
  setTimeout(()=>{savedMsg.classList.remove('vis');savedMsg.style.background='';},2500);
}

// Auto-save on change (shared debounce timer; no per-field state on DOM nodes)
fields.forEach(f=>f.addEventListener('input',()=>{updateProg();clearTimeout(saveTimer);saveTimer=setTimeout(save,1500)}));

// Progress — iterate NodeList directly; use cached DOM references
let lastFilled=0;
function updateProg(){
  lastFilled=0;
  fields.forEach(f=>{if(f.value.trim().length>0)lastFilled++});
  const pct=Math.round((lastFilled/totalFields)*100);
  progFill.style.width=pct+'%';
  progLabel.textContent=lastFilled+' von '+totalFields+' Feldern ausgefüllt ('+pct+'%)';
}

// Reset — native <dialog> handles focus trap, Escape, and backdrop
function showConfirm(){
  confirmTrigger=document.activeElement;
  confirmDialog.showModal();
}
function hideConfirm(){
  confirmDialog.close();
  if(confirmTrigger)confirmTrigger.focus();
}
function doReset(){
  fields.forEach(f=>f.value='');
  try{localStorage.removeItem(KEY)}catch(e){console.warn('Storage unavailable:',e.message)}
  hideConfirm();updateProg();
}

// Next-step hint after explicit save — shown once per session
let hintShown=false;
function showNextStepHint(){
  if(hintShown||lastFilled<3)return;
  hintShown=true;
  savedMsg.textContent='Gespeichert \u2713 — Drucken Sie den Plan und besprechen Sie ihn mit Ihrer Fachperson.';
  savedMsg.classList.add('vis');
  setTimeout(()=>savedMsg.classList.remove('vis'),5000);
}

// Button event wiring — unobtrusive, no inline handlers
document.getElementById('btnSave').addEventListener('click',()=>{save();setTimeout(showNextStepHint,2600)});
document.getElementById('btnPrint').addEventListener('click', () => window.print());
document.getElementById('btnReset').addEventListener('click', showConfirm);
document.getElementById('btnConfirmCancel').addEventListener('click', hideConfirm);
document.getElementById('btnConfirmDelete').addEventListener('click', doReset);
confirmDialog.addEventListener('click',e=>{if(e.target===confirmDialog)hideConfirm()});

// Print date
document.getElementById('printDate').textContent=new Date().toLocaleDateString('de-CH');
load();
</script>
{% endblock %}
