{% block scripts %}
<script>
const Q=[
  {id:1,t:"Ich denke oft daran, was als nächstes schiefgehen könnte — auch wenn es gerade ruhig ist."},
  {id:2,t:"Ich habe das Gefühl, meine eigenen Bedürfnisse kommen kaum noch vor."},
  {id:3,t:"Freunde oder Hobbys habe ich in letzter Zeit vernachlässigt."},
  {id:4,t:"Ich fühle mich oft allein mit dieser Situation — auch wenn Menschen um mich herum sind."},
  {id:5,t:"Manchmal frage ich mich, wie lange ich das noch durchhalte."}
];
const O=[{v:0,l:"Trifft nicht zu",e:"○"},{v:1,l:"Trifft selten zu",e:"◔"},{v:2,l:"Trifft manchmal zu",e:"◑"},{v:3,l:"Trifft oft zu",e:"◕"},{v:4,l:"Trifft fast immer zu",e:"●"}];
function gr(s){
  if(s<=6)return{lv:"niedrig",cls:"result--green",ti:"Belastung im grünen Bereich",tx:"Ihre Antworten deuten darauf hin, dass Sie aktuell gut zurechtkommen. Das bedeutet nicht, dass alles einfach ist — aber Sie scheinen Strategien zu haben, die funktionieren.",rc:["Lesen Sie Modul 7 zur langen Strecke und Tragfähigkeit — um tragende Routinen weiter zu stärken.","Bleiben Sie in Kontakt mit Ihrem sozialen Netz."]};
  if(s<=12)return{lv:"mittel",cls:"result--amber",ti:"Erhöhte Belastung — achten Sie auf sich",tx:"Ihre Antworten zeigen: Die Belastung ist spürbar. Das ist bei Angehörigen häufig — und kein Zeichen von Schwäche. Jetzt ist ein guter Zeitpunkt, aktiv gegenzusteuern.",rc:["Abschnitt 3 dieses Moduls (Schonhaltung & Identitätsverlust) könnte besonders relevant sein.","Modul 6 bietet konkrete Werkzeuge — insbesondere Grenzsetzung.","Sprechen Sie mit einer Vertrauensperson über Ihre Situation."]};
  return{lv:"hoch",cls:"result--red",ti:"Deutliche Überlastung — Sie verdienen Unterstützung",tx:"Ihre Antworten deuten auf eine erhebliche Belastung hin. Das ist ernst zu nehmen. Sie tragen gerade sehr viel. Es wäre wichtig, dass Sie sich jetzt Hilfe holen.",rc:["Fachstelle Angehörigenarbeit PUK Zürich: 058 384 38 00 — kostenlos, vertraulich.","Hausarzt einbeziehen: Chronische Belastung hat körperliche Folgen.","VASK Zürich (044 240 48 68) bietet Selbsthilfegruppen.","Lesen Sie Abschnitt 6 dieses Moduls — konkrete Handlungsschritte."]};
}
let ans={},cq=0,sr=false;
function rn(){
  const ad=Object.keys(ans).length,sc=Object.values(ans).reduce((a,b)=>a+b,0),aa=ad===Q.length;
  document.getElementById('prog').innerHTML=Q.map((_,i)=>`<div class="${i<ad?'done':i===cq&&!sr?'cur':''}"></div>`).join('');
  const cd=document.getElementById('card');
  if(!sr){
    cd.className='card';
    document.title=`Frage ${cq+1} / ${Q.length} — Selbsttest | PUK Zürich`;
    const q=Q[cq],cv=ans[q.id];
    cd.innerHTML=`<div class="qhdr"><div class="qnum">${cq+1}</div><p class="qtxt">${q.t}</p></div>
    <div class="opts">${O.map(o=>`<button class="opt${cv===o.v?' sel':''}" data-sa="${q.id}" data-sv="${o.v}"><span class="em" aria-hidden="true">${o.e}</span>${o.l}</button>`).join('')}</div>
    <div class="nav"><button class="btn btn-back" ${cq===0?'disabled':''} data-action="pv">← Zurück</button><span class="navlbl">${cq+1} / ${Q.length}</span>
    ${cq<Q.length-1?`<button class="btn btn-next" ${cv===undefined?'disabled':''} data-action="nx">Weiter →</button>`:`<button class="btn btn-next" ${!aa?'disabled':''} data-action="sh">Auswerten</button>`}</div>`;
  }else{
    document.title=`Ergebnis — Selbsttest | PUK Zürich`;
    const r=gr(sc);
    cd.className='card '+r.cls;
    cd.innerHTML=`<div class="res-top"><div class="res-score"><span>${sc}</span></div><div><div class="res-level">${r.lv==='niedrig'?'Grüner Bereich':r.lv==='mittel'?'Gelber Bereich':'Roter Bereich'}</div><div class="res-title">${r.ti}</div></div></div>
    <div class="bar-wrap"><div class="bar-labels"><span>0</span><span>niedrig</span><span>mittel</span><span>hoch</span><span>20</span></div><div class="bar"><div class="bar-dot" style="left:${(sc/20)*100}%"></div></div></div>
    <p class="res-txt">${r.tx}</p>
    <div class="rec"><div class="rec-title">Empfehlungen</div>${r.rc.map(x=>`<div class="rec-item">${x}</div>`).join('')}</div>
    <div class="disc"><strong>Wichtig:</strong> Dieser Selbsttest ist keine Diagnose. Er gibt Orientierung. Fachstelle PUK: <a href="tel:+41583843800">058 384 38 00</a>.</div>
    <div class="btns"><button class="btn-reset" data-action="rs">Erneut einschätzen</button><button class="btn-cont" data-action="nav" data-href="/modul/4/">Zurück zu Modul 4 →</button></div>`;
  }
}
function sa(id,v){ans[id]=v;rn()}
function nx(){cq++;rn()}
function pv(){cq--;rn()}
function sh(){sr=true;rn()}
function rs(){ans={};cq=0;sr=false;rn()}
rn();
document.addEventListener('click',function(e){
  const o=e.target.closest('[data-sa]');if(o){sa(Number(o.dataset.sa),Number(o.dataset.sv));return;}
  const a=e.target.closest('[data-action]');if(!a||a.disabled)return;
  if(a.dataset.action==='pv')pv();
  else if(a.dataset.action==='nx')nx();
  else if(a.dataset.action==='sh')sh();
  else if(a.dataset.action==='rs')rs();
  else if(a.dataset.action==='nav')location.href=a.dataset.href;
});
</script>
{% endblock %}
