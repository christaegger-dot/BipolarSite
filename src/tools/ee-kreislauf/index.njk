{% block scripts %}
<script>
const stations=[
  {n:"Schuld",c:"#B45309",desc:"Sie fühlen sich schuldig — «Ich mache nicht genug.» «Wenn ich nur aufmerksamer wäre.» Schuld ist in dieser Lage häufig und entsteht oft aus Liebe, Verantwortung und Hilflosigkeit zugleich.",mech:"Diese Schuld treibt oft dazu, noch mehr zu übernehmen, noch stärker zu kontrollieren und noch weniger loszulassen. So beginnt der Kreislauf.",exit:"Eine kleine Unterbrechung kann sein, Schuld zu benennen, ohne ihr sofort zu folgen: «Ich fühle mich schuldig, aber ich muss nicht alles allein auffangen.»"},
  {n:"Überengagement",c:"#9A3412",desc:"Sie übernehmen immer mehr — Medikamente, Termine, Finanzen, Stimmungskontrolle. Die Beziehung droht zur Daueraufgabe zu werden.",mech:"Überengagement soll schützen, kann aber auch signalisieren: «Du kannst das nicht selbst.» Das schwächt Eigenverantwortung und verstärkt auf Dauer die Überlastung beider Seiten.",exit:"Geben Sie eine kleine Aufgabe bewusst zurück. Nicht als Strafe, sondern als Schritt aus der Dauerübernahme."},
  {n:"Erschöpfung",c:"#5b7fa5",desc:"Die dauernde Überlastung führt zu Erschöpfung — körperlich, emotional, kognitiv. Viele funktionieren weiter, merken aber erst spät, wie dünn sie innerlich geworden sind.",mech:"Erschöpfung senkt die Toleranzschwelle. Was sonst gerade noch ging, wird schneller zu viel. Gereiztheit, Abstumpfung oder Härte nehmen zu.",exit:"Unterbrechen heisst hier oft nicht viel, sondern etwas Kleines und Konkretes: eine Pause, ein Anruf, ein Abend ohne Zuständigkeit."},
  {n:"Kritik",c:"#0d7a5f",desc:"Aus der Erschöpfung heraus wird der Ton schärfer. Kritik ist oft nicht bloss Härte, sondern Überforderungssprache.",mech:"Kritik erzeugt beim Partner eher Scham, Abwehr oder Rückzug — und bei Ihnen danach oft neue Schuld. So schliesst sich der Kreislauf erneut.",exit:"Eine realistische Unterbrechung ist Beobachtung statt Bewertung: «Ich sehe, dass du heute nicht aufgestanden bist» statt «Du liegst schon wieder im Bett.»"}
];
let active=null,broken=false;
function sel(i){active=active===i?null:i;rn()}
function doBreak(){broken=!broken;const breakBtn=document.getElementById('breakBtn');document.getElementById('svgWrap').classList.toggle('interrupted',broken);breakBtn.classList.toggle('active',broken);breakBtn.setAttribute('aria-pressed',broken?'true':'false');breakBtn.textContent=broken?'Kreislauf ist unterbrochen':'Kreislauf unterbrechen';document.getElementById('centerText1').textContent=broken?'✓':'Chronische';document.getElementById('centerText2').textContent=broken?'Unterbrochen':'Anspannung';if(broken){document.getElementById('centerText1').setAttribute('fill','#1e656d');document.getElementById('centerText2').setAttribute('fill','#1e656d')}else{document.getElementById('centerText1').setAttribute('fill','#1c2b3a');document.getElementById('centerText2').setAttribute('fill','#1c2b3a')}}
function rn(){
  [0,1,2,3].forEach(i=>document.getElementById('station'+i).setAttribute('aria-pressed',active===i?'true':'false'));
  document.querySelectorAll('[data-station-btn]').forEach(btn=>{
    const isActive=Number(btn.dataset.stationBtn)===active;
    btn.classList.toggle('is-active',isActive);
    btn.setAttribute('aria-pressed',isActive?'true':'false');
  });
  const d=document.getElementById('detail');
  if(active!==null){
    const s=stations[active];
    d.className='detail vis';
    d.innerHTML=`<div class="detail-num" style="color:${s.c}">Station ${active+1} — ${s.n}</div><h2>${s.n}</h2><p>${s.desc}</p><p style="font-size:0.82rem;color:var(--slate);font-style:italic">${s.mech}</p><div class="detail-exit"><div class="exit-lbl">Ausweg</div><p>${s.exit}</p></div>`;
  }else{d.className='detail'}
}
function onSvgKey(event,index){if(event.key==='Enter'||event.key===' '){event.preventDefault();sel(index)}}
[0,1,2,3].forEach(i=>{const el=document.getElementById('station'+i);el.addEventListener('click',()=>sel(i));el.addEventListener('keydown',event=>onSvgKey(event,i))});
document.querySelectorAll('[data-station-btn]').forEach(btn=>btn.addEventListener('click',()=>sel(Number(btn.dataset.stationBtn))));
document.getElementById('breakBtn').addEventListener('click',doBreak);
</script>
{% endblock %}
