      <p style="font-weight:600;margin:0 0 8px">Dieses Werkzeug benötigt JavaScript.</p>
      <p style="margin:0">Kommunikationshilfen finden Sie auch in <a href="/modul/6/" style="color:var(--teal);font-weight:600">Modul 6</a>.</p>
    </div>
  </noscript>
</main>
{% endblock %}
{% block footer %}
{% include "footer-medium.njk" %}
{% endblock %}
{% block scripts %}
<script>
const S=[
  {ph:"manie",pl:"Manie",sit:"Ihr Partner redet seit einer Stunde ohne Pause, springt von Thema zu Thema und wird immer aufgeregter.",opts:[
    {t:"«Kannst du bitte mal zuhören? Ich versuche dir seit einer Stunde zu erklären, dass…»",ok:false,fb:"Lange Erklärungen und die Aufforderung zuzuhören funktionieren in der Manie nicht — das Gehirn kann es physisch nicht. Das eskaliert die Situation."},
    {t:"«Mir fällt auf, dass du heute sehr viel Energie hast. Lass uns morgen darüber reden.»",ok:true,fb:"Kurz, eine Beobachtung, kein Vorwurf — und ein klarer Zeitpunkt. In der Manie gilt: ein Satz, ein Thema, dann Pause."}]},
  {ph:"depression",pl:"Depression",sit:"Ihr Partner liegt seit drei Tagen im Bett, reagiert kaum und sagt: «Es hat alles keinen Sinn.»",opts:[
    {t:"«Ich bin da. Du musst jetzt nichts sagen. Ich setze mich kurz zu dir.»",ok:true,fb:"Stille Präsenz ist in der Depression wertvoller als jedes Wort. Sie signalisieren: Ich halte das aus. Du musst nichts leisten."},
    {t:"«Du musst mal aufstehen und an die frische Luft — das wird dir guttun!»",ok:false,fb:"Gut gemeint, aber kontraproduktiv. Ihr Partner würde aufstehen, wenn er könnte. «Du musst» erzeugt Druck und verstärkt die Scham."}]},
  {ph:"manie",pl:"Manie",sit:"Ihr Partner hat über Nacht für CHF 3'000 Online-Käufe getätigt und sagt: «Das sind Investitionen!»",opts:[
    {t:"«Du gibst schon wieder unser ganzes Geld aus! Das ist jedes Mal dasselbe!»",ok:false,fb:"Vorwurf + «schon wieder» + «jedes Mal» — das ist der EE-Kreislauf in Reinform. Eskaliert sofort, ändert nichts."},
    {t:"«Ich mache mir Sorgen über die Ausgaben. Ich rufe morgen die Bank an. Jetzt gehen wir schlafen.»",ok:true,fb:"Ich-Botschaft, konkrete Massnahme, klare Grenze — ohne Eskalation. Die Manie lässt sich nicht wegdiskutieren."}]},
  {ph:"depression",pl:"Depression",sit:"Ihr Partner sagt unter Tränen: «Ich bin eine Last für euch alle. Ihr wärt besser dran ohne mich.»",opts:[
    {t:"«Quatsch! Du bist doch keine Last! Denk mal an alles, was wir zusammen haben.»",ok:false,fb:"Der Impuls ist verständlich — aber «Quatsch» entwertet das Gefühl. Ihr Partner fühlt sich nicht gehört, sondern korrigiert."},
    {t:"«Ich verstehe, dass es sich so anfühlt. Du bist mir wichtig — gerade jetzt.»",ok:true,fb:"Das Gefühl stehen lassen, ohne es zu bestätigen. Gleichzeitig Zuneigung zeigen. Sie dürfen das Gefühl halten."}]},
  {ph:"manie",pl:"Manie",sit:"Ihr Partner schreit Sie an, weil Sie seinen «genialen Geschäftsplan» nicht unterstützen. Die Situation eskaliert.",opts:[
    {t:"«Ich lasse mich nicht anschreien. Ich gehe jetzt ins Nebenzimmer. Wenn wir ruhig reden können, komme ich zurück.»",ok:true,fb:"Grenze + Konsequenz + Rückkehr-Signal. Sie schützen sich, ohne die Beziehung abzubrechen."},
    {t:"«Wenn du so weitermachst, gehe ich! Dann kannst du sehen, wie du alleine klarkommst!»",ok:false,fb:"Drohungen werden in der Manie nicht ernst genommen — oder sie eskalieren massiv. Eine Drohung ist keine Grenze."}]},
  {ph:"depression",pl:"Depression",sit:"Seit Wochen kaum Besserung. Sie haben alles versucht — reden, kochen, Spaziergänge vorschlagen. Nichts hilft.",opts:[
    {t:"Immer neue Vorschläge machen: «Hast du es schon mit Yoga probiert? Oder vielleicht Johanniskraut?»",ok:false,fb:"Jeder neue Vorschlag signalisiert: Was du tust, reicht nicht. Sie sind nicht die Therapie — Ihre Anwesenheit reicht."},
    {t:"«Ich kann das nicht lösen. Aber ich bin hier. Und ich gehe nirgendwo hin.»",ok:true,fb:"Dieser Satz entlastet Sie beide. Sie von der Verantwortung, alles zu reparieren. Ihren Partner vom Druck, sich «zusammenzureissen»."}]}
  ,{ph:"frueh",pl:"Frühwarnung",sit:"Sie bemerken seit einigen Tagen, dass Ihr Partner weniger schläft als sonst, lebhafter wirkt und schneller redet. Er selbst sieht kein Problem.",opts:[
    {t:"«Ich glaube, du wirst wieder manisch. Ich rufe sofort deinen Arzt an.»",ok:false,fb:"Der direkte Alarmton erzeugt Abwehr. In der Frühwarnphase ist der Spielraum für Kooperation noch da — diesen sollten Sie nutzen, bevor er sich schliesst."},
    {t:"«Mir fällt auf, dass du die letzten drei Nächte weniger geschlafen hast. Magst du das auch wahrnehmen?»",ok:true,fb:"Beobachtung ohne Anklage, Einbeziehung statt Überfahren. In der Frühwarnphase ist das Ziel: die Person einladen, selbst hinzuschauen — nicht überzeugen, dass etwas falsch ist."}]},
  {ph:"nach",pl:"Nach der Krise",sit:"Die manische Episode liegt drei Wochen zurück. Ihr Partner ist stabil. Sie tragen noch verletzende Aussagen und Situationen aus der Krise mit sich.",opts:[
    {t:"«Wir müssen jetzt alles aufarbeiten. Du musst verstehen, was du mir angetan hast.»",ok:false,fb:"Der Wunsch nach Aufarbeitung ist verständlich — aber «du musst» und «alles» erzeugen Druck. In der Nachphase braucht es einen behutsamen Einstieg, keinen konfrontativen."},
    {t:"«Ich trage noch einige Dinge aus letztem Monat mit mir. Ich fände es gut, wenn wir dafür irgendwann einen Moment finden — wenn du bereit bist.»",ok:true,fb:"Ehrlich über das eigene Tragen, ohne Anklage. Das «wenn du bereit bist» gibt Kontrolle zurück. Beides ist möglich: die Episode war krankheitsbedingt — und das Erlebte war verletzend."}]}
];
let ci=0,sel=null,score={ok:0,total:0},fin=false;
// Shuffle options per scenario (fixed per session)
const shuf=S.map(s=>Math.random()>0.5?[...s.opts]:[...s.opts].reverse());
const elProg=document.getElementById('prog');
const elCd=document.getElementById('card');
function rn(){
  elProg.innerHTML=S.map((_,i)=>`<div class="${i<score.total?'done':i===ci&&!fin?'cur':''}"></div>`).join('');
  if(!fin){
    const s=S[ci],opts=shuf[ci];
    elCd.innerHTML=`<div class="card-body"><div class="phase-row"><div class="phase-badge phase-${s.ph[0]}">${s.pl}</div><span class="phase-count">Situation ${ci+1} / ${S.length}</span></div><p class="sit">${s.sit}</p><div class="olbl">Wie reagieren Sie?</div>
    ${opts.map((o,i)=>{
      const revealed=sel!==null;const isSel=sel===i;const isOk=o.ok;
      let cls='opt-btn';if(revealed){if(isOk)cls+=' correct';else if(isSel&&!isOk)cls+=' wrong';else cls+=' dimmed'}
      let html=`<button class="${cls}" ${revealed?'disabled':''} data-pick="${i}"><span class="mark">${revealed?(isOk?'✓':'✗'):''}</span>${o.t}</button>`;
      if(revealed&&(isSel||isOk))html+=`<div class="fb ${isOk?'fb-ok':'fb-no'}">${o.fb}</div>`;
      return html;
    }).join('')}
    ${sel!==null?`<button class="btn-next" data-action="nx">${ci<S.length-1?'Nächste Situation →':'Auswertung →'}</button>`:''}
    </div>`;
  }else{
    const pct=Math.round((score.ok/S.length)*100);
    const col=pct>=80?'#0d7a5f':pct>=50?'#B45309':'#9A3412';
    const bg=pct>=80?'#e6f4f2':pct>=50?'#fef3e2':'#FEF2F2';
    elCd.innerHTML=`<div class="res"><div class="res-circle" style="background:${bg};border-color:${col}"><span style="color:${col}">${score.ok}/${S.length}</span></div>
    <h2>${pct>=80?'Sie haben ein gutes Gespür für die Unterschiede.':pct>=50?'Eine brauchbare Basis ist da — mit Übung wird es klarer.':'Kommunikation unter Druck ist schwer — genau dafür ist diese Übung da.'}</h2>
    <p>${pct>=80?'Sie erkennen recht gut, warum Manie und Depression unterschiedliche Sprache brauchen.':'Die Situationen sind absichtlich schwer — im echten Leben bleibt oft kaum Zeit. Entscheidend sind nicht perfekte Sätze, sondern die Grundrichtung.'}</p>
    <div class="rules"><div class="rules-title">Die zwei Grundregeln</div><p><strong>Manie:</strong> Kurz, klar, ein Thema. Nicht argumentieren. Rausgehen, wenn es eskaliert.</p><p><strong>Depression:</strong> Stille Präsenz. Nicht aufmuntern. Gefühle stehen lassen, nicht korrigieren.</p></div>
    <div class="btns"><button class="btn-r" data-action="rs">Erneut üben</button><button class="btn-c" data-action="nav" data-href="/modul/6/">Zurück zu Modul 6 →</button></div></div>`;
  }
}
function pick(i){if(sel!==null)return;sel=i;const o=shuf[ci][i];score.ok+=o.ok?1:0;score.total++;rn()}
function nx(){sel=null;if(ci<S.length-1)ci++;else fin=true;rn()}
function rs(){ci=0;sel=null;score={ok:0,total:0};fin=false;rn()}
rn();
document.addEventListener('click',function(e){
  const p=e.target.closest('[data-pick]');if(p&&!p.disabled){pick(Number(p.dataset.pick));return;}
  const a=e.target.closest('[data-action]');if(!a||a.disabled)return;
  if(a.dataset.action==='nx')nx();
  else if(a.dataset.action==='rs')rs();
  else if(a.dataset.action==='nav')location.href=a.dataset.href;
});
</script>
{% endblock %}
