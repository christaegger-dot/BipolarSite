---
layout: "base"
title: "Bipolarer Phasenverlauf — Interaktiv | PUK Zürich"
description: "Interaktive Visualisierung des bipolaren Phasenverlaufs: Manie, Hypomanie, Euthymie und Depression im zeitlichen Zusammenhang. Für Angehörige. PUK Zürich."
permalink: "/tools/phasenverlauf/"
toolBackHref: "/modul/1/"
toolBackLabel: "Zurück zu Modul 1"
useSharedCSS: true
useNavJS: false
useToolCSS: true
bodyClass: "phasenverlauf-page"
breadcrumbs:
  - name: "Werkzeuge"
    url: "/werkzeuge/"
  - name: "Phasenverlauf"
    url: "/tools/phasenverlauf/"
---
{% block headCSS %}<!-- Phasenverlauf styles migrated to tools.css (P2.4) -->{% endblock %}
{% block nav %}
{% include "nav-tool.njk" %}
{% endblock %}
{% block content %}
<main class="wrap" id="main-content">
  <div class="hdr">
<div class="breadcrumb"><a href="/">Startseite</a><span class="sep" aria-hidden="true">›</span><a href="/werkzeuge/">Werkzeuge</a><span class="sep" aria-hidden="true">›</span><span>Phasenverlauf</span></div>
    <div class="tool-glyph" aria-hidden="true">
      <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M5 25C10 25 10 9 16 9C22 9 22 31 28 31C32 31 32 18 35 18" stroke="var(--teal-light)" stroke-width="3.6" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="16" cy="9" r="3" fill="var(--amber-light)"/>
        <circle cx="28" cy="31" r="3" fill="var(--blue-phase)"/>
      </svg>
    </div>
    <h1>Bipolarer Phasenverlauf</h1>
    <p>Wählen Sie eine Phase — entweder im Diagramm oder über die Schaltflächen — um zu erfahren, was sie für Betroffene und Angehörige bedeutet.</p>
  </div>
  <div class="mobile-chart-note">Auf kleinen Screens ist das Diagramm ausgeblendet, damit die Seite ruhiger bleibt. Wählen Sie unten direkt eine Phase, um die Einordnung zu lesen.</div>

  <!-- Chart -->
  <div class="chart-wrap">
    <div class="chart-top">
      <span class="chart-heading">Stimmungsverlauf über die Zeit</span>
      <div class="chart-legend">
        <span class="leg"><span class="leg-dot leg-dot--mania"></span>Manie</span>
        <span class="leg"><span class="leg-dot leg-dot--hypo"></span>Hypomanie</span>
        <span class="leg"><span class="leg-dot leg-dot--stable"></span>Stabil</span>
        <span class="leg"><span class="leg-dot leg-dot--dep-mild"></span>Leichte Dep.</span>
        <span class="leg"><span class="leg-dot leg-dot--dep-severe"></span>Schwere Dep.</span>
      </div>
    </div>
    <div class="chart-svg-wrap">
      <!--
        ViewBox 0 0 540 280
        5 horizontal zones (each 56px tall):
          Manie:           y   0 – 56   mid y=28
          Hypomanie:       y  56 – 112  mid y=84
          Stabil:          y 112 – 168  mid y=140
          Leichte Dep.:    y 168 – 224  mid y=196
          Schwere Dep.:    y 224 – 280  mid y=252

        Wave path (x range 90–530):
          Start  x=90,  y=140 (stabil)
          Manie  x=160, y=28
          Stabil x=230, y=140
          Schwere Dep. x=300, y=252
          Stabil x=370, y=140
          Hypo   x=430, y=84
          Stabil x=490, y=140
          Mild Dep. x=520, y=196  → end x=530, y=196
      -->
      <svg class="chart-svg" viewBox="0 0 540 280" xmlns="http://www.w3.org/2000/svg"
           role="img" aria-label="Vereinfachter bipolarer Phasenverlauf. Interaktiv — Phasen anklicken für Details.">

        <!-- Zone backgrounds -->
        <rect x="0" y="0"   width="540" height="56"  fill="var(--amber-bg)" id="zone-mania"       class="zone-bg" data-phase="mania"/>
        <rect x="0" y="56"  width="540" height="56"  fill="var(--hypo-phase-bg)" id="zone-hypo"        class="zone-bg" data-phase="hypomania"/>
        <rect x="0" y="112" width="540" height="56"  fill="var(--success-soft)" id="zone-stable"      class="zone-bg" data-phase="stable"/>
        <rect x="0" y="168" width="540" height="56"  fill="var(--blue-phase-light)" id="zone-mild"        class="zone-bg" data-phase="mild-dep"/>
        <rect x="0" y="224" width="540" height="56"  id="zone-severe"      class="zone-bg" data-phase="severe-dep"/>

        <!-- Zone separators -->
        <line x1="0" y1="56"  x2="540" y2="56"  stroke="var(--border-warm-md)" stroke-width="0.6" stroke-dasharray="4 3"/>
        <line x1="0" y1="112" x2="540" y2="112" stroke="var(--border-warm-md)" stroke-width="0.6" stroke-dasharray="4 3"/>
        <line x1="0" y1="168" x2="540" y2="168" stroke="var(--border-warm-md)" stroke-width="1"/>
        <line x1="0" y1="224" x2="540" y2="224" stroke="var(--border-warm-md)" stroke-width="0.6" stroke-dasharray="4 3"/>

        <!-- Baseline (stable midline) -->
        <line x1="80" y1="140" x2="540" y2="140" stroke="var(--phase-green)" stroke-width="0.8" stroke-dasharray="6 4" opacity="0.35"/>

        <!-- Zone labels -->
        <text x="8" y="32"  font-size="10" fill="var(--amber)" font-weight="700" font-family="DM Sans,sans-serif">Manie</text>
        <text x="8" y="88"  font-size="10" fill="var(--hypo-phase)" font-weight="700" font-family="DM Sans,sans-serif">Hypomanie</text>
        <text x="8" y="144" font-size="10" fill="var(--phase-green)" font-weight="700" font-family="DM Sans,sans-serif">Stabil</text>
        <text x="8" y="200" font-size="10" fill="var(--blue-phase)" font-weight="700" font-family="DM Sans,sans-serif">Leichte Dep.</text>
        <text x="8" y="256" font-size="10" fill="var(--slate)" font-weight="700" font-family="DM Sans,sans-serif">Schwere Dep.</text>

        <!-- Clickable zone hit areas (full width, for accessibility) -->
        <rect x="0" y="0"   width="540" height="56"  class="zone-hit" data-phase="mania"      id="hit-mania" aria-hidden="true" focusable="false"/>
        <rect x="0" y="56"  width="540" height="56"  class="zone-hit" data-phase="hypomania"  id="hit-hypo" aria-hidden="true" focusable="false"/>
        <rect x="0" y="112" width="540" height="56"  class="zone-hit" data-phase="stable"     id="hit-stable" aria-hidden="true" focusable="false"/>
        <rect x="0" y="168" width="540" height="56"  class="zone-hit" data-phase="mild-dep"   id="hit-mild" aria-hidden="true" focusable="false"/>
        <rect x="0" y="224" width="540" height="56"  class="zone-hit" data-phase="severe-dep" id="hit-severe" aria-hidden="true" focusable="false"/>

        <!-- Wave path (animated in) -->
        <path id="wavePath"
          d="M 90,140 C 115,140 130,28 160,28 C 190,28 205,140 230,140 C 255,140 270,252 300,252 C 330,252 345,140 370,140 C 390,140 405,84 430,84 C 455,84 465,140 490,140 C 505,140 510,196 520,196"
          stroke="var(--teal)" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>

        <!-- Interactive wave points -->
        <circle class="wpt" cx="160" cy="28"  r="9" fill="var(--amber)" stroke="var(--card)" stroke-width="2.5" data-phase="mania"      id="pt-mania" tabindex="0" role="button" aria-label="Manie auswählen"/>
        <circle class="wpt" cx="300" cy="252" r="9" fill="var(--slate)" stroke="var(--card)" stroke-width="2.5" data-phase="severe-dep" id="pt-severe" tabindex="0" role="button" aria-label="Schwere Depression auswählen"/>
        <circle class="wpt" cx="370" cy="140" r="9" fill="var(--phase-green)" stroke="var(--card)" stroke-width="2.5" data-phase="stable"     id="pt-stable" tabindex="0" role="button" aria-label="Stabile Phase auswählen"/>
        <circle class="wpt" cx="430" cy="84"  r="9" fill="var(--hypo-phase)" stroke="var(--card)" stroke-width="2.5" data-phase="hypomania"  id="pt-hypo" tabindex="0" role="button" aria-label="Hypomanie auswählen"/>
        <circle class="wpt" cx="520" cy="196" r="9" fill="var(--blue-phase)" stroke="var(--card)" stroke-width="2.5" data-phase="mild-dep"   id="pt-mild" tabindex="0" role="button" aria-label="Leichte Depression auswählen"/>

        <!-- Pulse rings (animated) -->
        <circle cx="160" cy="28"  r="15" fill="none" stroke="var(--amber)" stroke-width="1.5" opacity="0" class="pulse" id="pulse-mania"/>
        <circle cx="300" cy="252" r="15" fill="none" stroke="var(--slate)" stroke-width="1.5" opacity="0" class="pulse" id="pulse-severe"/>
        <circle cx="370" cy="140" r="15" fill="none" stroke="var(--phase-green)" stroke-width="1.5" opacity="0" class="pulse" id="pulse-stable"/>
        <circle cx="430" cy="84"  r="15" fill="none" stroke="var(--hypo-phase)" stroke-width="1.5" opacity="0" class="pulse" id="pulse-hypo"/>
        <circle cx="520" cy="196" r="15" fill="none" stroke="var(--blue-phase)" stroke-width="1.5" opacity="0" class="pulse" id="pulse-mild"/>
      </svg>
    </div>
    <p class="chart-xlab">Zeit (vereinfacht — Episodenabstände variieren stark, von Wochen bis Jahren)</p>
  </div>

  <p class="hint">Klicken Sie auf einen Punkt im Diagramm oder wählen Sie eine Phase:</p>

  <!-- Phase selector buttons -->
  <div class="phase-btns" role="group" aria-label="Phase auswählen">
    <button class="pbtn" data-phase="mania"      aria-pressed="false"><span class="ico">↑↑</span>Manie</button>
    <button class="pbtn" data-phase="hypomania"  aria-pressed="false"><span class="ico">↑</span>Hypomanie</button>
    <button class="pbtn" data-phase="stable"     aria-pressed="false"><span class="ico">→</span>Stabil</button>
    <button class="pbtn" data-phase="mild-dep"   aria-pressed="false"><span class="ico">↓</span>Leichte Dep.</button>
    <button class="pbtn" data-phase="severe-dep" aria-pressed="false"><span class="ico">↓↓</span>Schwere Dep.</button>
  </div>

  <!-- Detail card -->
  <div class="detail-card" id="detailCard" aria-live="polite"></div>
  <noscript>
    <div class="noscript-box">
      <p>Die interaktive Visualisierung benötigt JavaScript.</p>
      <p>Die Phasen und ihre Bedeutung finden Sie auch in <a href="/modul/1/">Modul 1</a>.</p>
    </div>
  </noscript>

</main>
{% endblock %}
{% block footer %}
{% include "footer-medium.njk" %}
{% endblock %}
{% block scripts %}
<script>
const PHASES = {
  'mania': {
    name: 'Manie',
    subtitle: 'Ausgeprägte Hochphase — oft mit Realitätsverlust',
    duration: 'Typisch: 2–4 Wochen bis mehrere Monate',
    color: 'var(--amber)',
    bg: 'var(--mania-phase-bg)',
    border: 'var(--mania-phase-border)',
    ptId: 'pt-mania',
    pulseId: 'pulse-mania',
    person: [
      'Gesteigerte Energie, kaum Schlafbedürfnis',
      'Grandiose Pläne, übersteigertes Selbstwertgefühl',
      'Impulsive Entscheidungen (Geld, Beziehungen, Risiken)',
      'Reizbarkeit und Gereiztheit bei Widerstand',
      'Häufig fehlende Krankheitseinsicht'
    ],
    caregiver: [
      'Schlafmangel durch nächtliche Aktivität',
      'Schwierigkeiten, die Person zu bremsen',
      'Finanzielle Schäden, Eskalation und Beschämung',
      'Angst vor Fremdgefährdung oder Rufschaden',
      'Wird als «Bremse» erlebt, nicht als Schutz'
    ],
    note: '<strong>Wichtig:</strong> Manie kann so schwer werden, dass eine Hospitalisation nötig ist. Das frühzeitige Erkennen von Frühwarnzeichen ist entscheidend. Krisenplan in stabiler Phase erstellen.'
  },
  'hypomania': {
    name: 'Hypomanie',
    subtitle: 'Abgeschwächte Hochphase — schwer erkennbar',
    duration: 'Typisch: 4 Tage bis 2 Wochen',
    color: 'var(--hypo-phase)',
    bg: 'var(--hypo-phase-bg)',
    border: '#fde68a',
    ptId: 'pt-hypo',
    pulseId: 'pulse-hypo',
    person: [
      'Erhöhte Energie und Produktivität',
      'Reduziertes Schlafbedürfnis (ohne Erschöpfungsgefühl)',
      'Gesteigertes Selbstvertrauen und Kreativität',
      'Leichte Enthemmung und erhöhte Risikobereitschaft',
      'Keine offensichtlichen psychotischen Symptome'
    ],
    caregiver: [
      'Für andere oft als «gute Phase» wahrnehmbar',
      'Innere Anspannung: «Ist das der Beginn einer Manie?»',
      'Partner*in wird als übertrieben besorgt abgetan',
      'Schwer, Unterstützung zu suchen — von aussen kein Problem sichtbar',
      'Übergang zu Manie kann schnell und unerwartet passieren'
    ],
    note: '<strong>Hypomanie ist tückisch:</strong> Sie wirkt nach aussen oft produktiv oder erleichternd — auch für das direkte Umfeld. Gerade für Angehörige ist das schwierig: Sie erkennen das Muster früher und werden trotzdem nicht ernst genommen.'
  },
  'stable': {
    name: 'Stabile Phase (Euthymie)',
    subtitle: 'Keine Episode — aber nicht immer innere Entwarnung',
    duration: 'Sehr variabel: Wochen bis Jahre',
    color: 'var(--phase-green)',
    bg: 'var(--success-soft)',
    border: 'var(--teal-light)',
    ptId: 'pt-stable',
    pulseId: 'pulse-stable',
    person: [
      'Normales Funktionsniveau',
      'Kann aktiv an Behandlung und Planung mitwirken',
      'Manche spüren Restsymptome oder Erschöpfung',
      'Oft Scham über das Verhalten in Episoden',
      'Wichtige Zeit für Krisenplanung und Vereinbarungen'
    ],
    caregiver: [
      'Äusserliche Ruhe — aber innere Hypervigilanz bleibt oft',
      'Ständiges inneres Prüfen: «Ist das wirklich stabil?»',
      'Angst, durch schwierige Gespräche die Phase zu kippen',
      'Wichtiges Zeitfenster für gemeinsamen Krisenplan',
      'Eigene Erholung kommt häufig zu kurz'
    ],
    note: '<strong>Stabile Phasen sind wertvoll.</strong> Sie sind der richtige Moment für Gespräche, Vereinbarungen und Erholung — auch für Angehörige. Nutzen Sie diese Zeit für gemeinsame Planung, z. B. mit dem <a href="/tools/krisenplan/" style="color:var(--phase-green);font-weight:600">Krisenplan-Werkzeug</a>.'
  },
  'mild-dep': {
    name: 'Leichte bis mittelschwere Depression',
    subtitle: 'Rückzug, Erschöpfung, schleichende Unerreichbarkeit',
    duration: 'Typisch: 2 Wochen bis 3 Monate',
    color: 'var(--blue-phase)',
    bg: 'var(--blue-phase-light)',
    border: 'var(--mild-dep-phase-border)',
    ptId: 'pt-mild',
    pulseId: 'pulse-mild',
    person: [
      'Antriebslosigkeit, Erschöpfung, Interesseverlust',
      'Sozialer Rückzug und Isolation',
      'Grübeln, Schlafstörungen, Appetitverlust',
      'Konzentrationsprobleme im Alltag',
      'Gefühl der Wertlosigkeit oder Schuld'
    ],
    caregiver: [
      'Die Person ist körperlich da, aber emotional unerreichbar',
      'Gefühl, hilflos zu sein — nichts, was man tut, hilft',
      'Übernahme aller Alltagsaufgaben und Verantwortung',
      'Eigene Einsamkeit und Erschöpfung wächst still',
      'Unsicherheit: Ansprechen oder lieber in Ruhe lassen?'
    ],
    note: '<strong>Wichtig:</strong> In depressiven Phasen ist aktive Unterstützung wichtig — ohne Druck. Wenn Sie sich überfordert fühlen, wenden Sie sich an die Fachstelle Angehörigenarbeit: <a href="tel:+41583843800" style="color:var(--blue-phase);font-weight:600">058&nbsp;384&nbsp;38&nbsp;00</a>.'
  },
  'severe-dep': {
    name: 'Schwere Depression',
    subtitle: 'Tiefste Erschöpfung — oft mit Suizidrisiko',
    duration: 'Variabel: Wochen bis Monate',
    color: 'var(--slate)',
    bg: 'var(--severe-dep-phase-bg)',
    border: 'var(--severe-dep-phase-border)',
    ptId: 'pt-severe',
    pulseId: 'pulse-severe',
    person: [
      'Schwere Antriebslosigkeit und Hoffnungslosigkeit',
      'Suizidale Gedanken möglich — ernst nehmen',
      'Kaum Fähigkeit, sich zu bewegen oder zu sprechen',
      'Vollständiger Rückzug und Isolation',
      'Psychotische Symptome bei schwerer Episode möglich'
    ],
    caregiver: [
      'Angst um das Leben der Person — rund um die Uhr',
      'Vollständige Übernahme aller Aufgaben, totale Erschöpfung',
      'Schwere emotionale Belastung und Hilflosigkeit',
      'Unklare Grenze: Wann ist eine Hospitalisation nötig?',
      'Eigene Schlafstörungen, Traumatisierung möglich'
    ],
    note: '<strong>⚠ Bei Suizidgedanken:</strong> Ärztefon – Notfalldienst ZH: <a href="tel:+41800336655" style="color:var(--slate);font-weight:600">0800&nbsp;33&nbsp;66&nbsp;55</a> (24/7, kostenlos). Dargebotene Hand: <a href="tel:143" style="color:var(--slate);font-weight:600">143</a>. Angehörige brauchen jetzt selbst Unterstützung: <a href="tel:+41583843800" style="color:var(--slate);font-weight:600">058&nbsp;384&nbsp;38&nbsp;00</a>.'
  }
};

let active = null;

function selectPhase(phase) {
  if (active === phase) return;
  active = phase;
  const d = PHASES[phase];

  // Update buttons
  document.querySelectorAll('.pbtn').forEach(b => {
    const isMe = b.dataset.phase === phase;
    b.setAttribute('aria-pressed', isMe ? 'true' : 'false');
    b.classList.toggle('active', isMe);
    if (isMe) {
      b.style.background = d.color;
      b.style.borderColor = d.color;
      b.style.color = 'var(--cta-primary-text)';
    } else {
      b.style.background = 'var(--bg)';
      b.style.borderColor = 'transparent';
      b.style.color = 'var(--slate)';
    }
  });

  // Fade zones
  document.querySelectorAll('.zone-bg').forEach(z => {
    z.style.opacity = z.dataset.phase === phase ? '1' : '0.4';
    z.style.transition = 'opacity 0.3s';
  });

  // Wave points
  document.querySelectorAll('.wpt').forEach(pt => {
    const isMe = pt.dataset.phase === phase;
    pt.setAttribute('r', isMe ? '12' : '9');
    pt.style.filter = isMe ? `drop-shadow(0 0 6px ${d.color})` : 'none';
  });

  // Show pulse ring
  document.querySelectorAll('.pulse').forEach(p => { p.style.opacity = '0'; });
  const pulse = document.getElementById(d.pulseId);
  if (pulse) {
    pulse.style.opacity = '0.5';
    pulse.style.transition = 'none';
    setTimeout(() => { pulse.style.transition = 'opacity 0.8s'; pulse.style.opacity = '0'; }, 100);
  }

  // Render detail card
  const card = document.getElementById('detailCard');
  card.style.borderLeftColor = d.color;
  card.innerHTML = `
    <div class="det-top">
      <div class="det-icon" style="background:${d.bg}">${d.name === 'Manie' ? '↑↑' : d.name === 'Hypomanie' ? '↑' : d.name.includes('Stabil') ? '→' : d.name.includes('Schwere') ? '↓↓' : '↓'}</div>
      <div>
        <div class="det-phase-name" style="color:${d.color}">${d.name}</div>
        <div class="det-title">${d.subtitle}</div>
      </div>
    </div>
    <div class="det-dur">⏱ ${d.duration}</div>
    <div class="det-cols">
      <div class="det-col" style="background:${d.bg};border-color:${d.color}">
        <div class="det-col-lbl" style="color:${d.color}">Für die erkrankte Person</div>
        <ul>${d.person.map(i => `<li>${i}</li>`).join('')}</ul>
      </div>
      <div class="det-col" style="background:var(--caregiver-col-bg);border-color:var(--teal-light)">
        <div class="det-col-lbl" style="color:var(--slate)">Für Angehörige</div>
        <ul>${d.caregiver.map(i => `<li>${i}</li>`).join('')}</ul>
      </div>
    </div>
    <div class="det-note" style="background:${d.bg}">${d.note}</div>
  `;
  card.classList.add('vis');
  // Scroll card into view
  setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
}

// Wave animation on load
window.addEventListener('load', () => {
  const path = document.getElementById('wavePath');
  if (!path || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    // Skip animation, just show pulse hints
    showPulseHints();
    return;
  }
  const len = path.getTotalLength();
  path.style.strokeDasharray = len;
  path.style.strokeDashoffset = len;
  path.style.transition = 'stroke-dashoffset 2s cubic-bezier(0.4,0,0.2,1)';
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      path.style.strokeDashoffset = '0';
      setTimeout(showPulseHints, 2200);
    });
  });
});

function showPulseHints() {
  // Show subtle pulse rings on all points to invite interaction
  document.querySelectorAll('.pulse').forEach((p, i) => {
    setTimeout(() => {
      p.style.transition = 'opacity 0.5s';
      p.style.opacity = '0.45';
      setTimeout(() => { p.style.opacity = '0'; }, 1200);
    }, i * 200);
  });
}

// Make zone hit areas and wave points interactive
document.querySelectorAll('.zone-hit, .wpt').forEach(el => {
  el.addEventListener('click', () => selectPhase(el.dataset.phase));
});
// Keyboard support for wave points (Enter/Space)
document.querySelectorAll('.wpt').forEach(el => {
  el.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectPhase(el.dataset.phase); }
  });
});

// Phase selector buttons — event delegation, no inline handlers
document.querySelector('.phase-btns').addEventListener('click', e => {
  const btn = e.target.closest('.pbtn[data-phase]');
  if (btn) selectPhase(btn.dataset.phase);
});

// Auto-highlight first phase after animation
setTimeout(() => { if (!active) selectPhase('mania'); }, 2400);
</script>
{% endblock %}
