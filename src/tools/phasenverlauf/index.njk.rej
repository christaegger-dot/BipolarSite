-.chart-wrap{width:100%;border-radius:22px;overflow:hidden;background:linear-gradient(180deg,#ffffff 0%,#fbfcfd 100%);border:1px solid var(--border-warm-md);box-shadow:0 12px 34px rgba(28,43,58,0.08);margin-bottom:18px}
