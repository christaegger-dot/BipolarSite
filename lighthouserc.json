{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:8080/",
        "http://localhost:8080/notfall/",
        "http://localhost:8080/modul/1/",
        "http://localhost:8080/modul/8/",
        "http://localhost:8080/werkzeuge/",
        "http://localhost:8080/tools/krisenplan/",
        "http://localhost:8080/tools/selbsttest/",
        "http://localhost:8080/tools/phasenverlauf/",
        "http://localhost:8080/tools/eisberg/",
        "http://localhost:8080/tools/komm-trainer/",
        "http://localhost:8080/tools/saeulen-check/",
        "http://localhost:8080/tools/durchatmen/",
        "http://localhost:8080/tools/ee-kreislauf/",
        "http://localhost:8080/tools/solidaritaets-chart/"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "^http://localhost:8080/modul/1/$",
          "assertions": {
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:performance": [
              "error",
              {
                "minScore": 0.83
              }
            ],
            "categories:best-practices": [
              "error",
              {
                "minScore": 0.95
              }
            ],
            "categories:seo": [
              "error",
              {
                "minScore": 0.9
              }
            ]
          }
        },
        {
          "matchingUrlPattern": "^http://localhost:8080/modul/8/$",
          "assertions": {
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:performance": [
              "error",
              {
                "minScore": 0.82
              }
            ],
            "categories:best-practices": [
              "error",
              {
                "minScore": 0.95
              }
            ],
            "categories:seo": [
              "error",
              {
                "minScore": 0.9
              }
            ]
          }
        },
        {
          "matchingUrlPattern": "^http://localhost:8080/(?!modul/1/|modul/8/).*$",
          "assertions": {
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:performance": [
              "error",
              {
                "minScore": 0.85
              }
            ],
            "categories:best-practices": [
              "error",
              {
                "minScore": 0.95
              }
            ],
            "categories:seo": [
              "error",
              {
                "minScore": 0.9
              }
            ]
          }
        }
      ]
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./.lighthouseci"
    }
  }
}
