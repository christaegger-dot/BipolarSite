{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:8080/",
        "http://localhost:8080/notfall/",
        "http://localhost:8080/modul/1/",
        "http://localhost:8080/modul/8/",
        "http://localhost:8080/werkzeuge/",
        "http://localhost:8080/tools/krisenplan/"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility":  ["error", {"minScore": 0.9}],
        "categories:performance":    ["error", {"minScore": 0.85}],
        "categories:best-practices": ["error", {"minScore": 0.95}],
        "categories:seo":            ["error", {"minScore": 0.9}]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./.lighthouseci"
    }
  }
}
